<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>회원가입 - FIDS</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: "Pretendard", "Apple SD Gothic Neo", Arial, sans-serif;
      background: #f5f6fa;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: #10172f;
    }

    .brand {
      text-align: center;
      margin-bottom: 28px;
    }

    .brand-title {
      font-size: 26px;
      font-weight: 700;
      letter-spacing: 1px;
      color: #16213a;
    }

    .brand-line {
      display: block;
      width: 32px;
      height: 3px;
      background: #2d6be4;
      border-radius: 2px;
      margin: 8px auto 12px;
    }

    .brand-desc {
      font-size: 13px;
      color: #9aa0ad;
      line-height: 1.7;
    }

    .page {
      width: 480px;
      background: #fff;
      border: 1px solid #e8e9ed;
      border-radius: 16px;
      padding: 42px 48px;
      box-shadow: 0 4px 40px rgba(0, 0, 0, 0.08);
    }

    .form-title {
      font-size: 22px;
      font-weight: 800;
      color: #0f172f;
      margin-bottom: 8px;
    }

    .form-sub {
      font-size: 13px;
      color: #9aa0ad;
      margin-bottom: 26px;
    }

    .grid2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .field {
      margin-bottom: 14px;
      position: relative;
    }

    .field label {
      display: block;
      font-size: 12px;
      font-weight: 700;
      color: #444b5c;
      margin-bottom: 7px;
    }

    .input-wrap {
      position: relative;
    }

    .input-wrap i {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 16px;
      color: #c3c7d0;
      z-index: 1;
    }

    .input-wrap input {
      width: 100%;
      height: 44px;
      border-radius: 9px;
      border: 1.5px solid #e4e7ee;
      background: #fbfbfc;
      padding: 0 14px 0 38px;
      font-size: 13px;
      color: #222;
      outline: none;
      transition: border .15s, background .15s;
      font-family: inherit;
    }

    .input-wrap input:focus {
      border-color: #2d6be4;
      background: #fff;
    }

    .email-row {
      display: flex;
      gap: 8px;
    }

    .email-input {
      display: flex;
      flex: 1;
    }

    .email-input .input-wrap {
      flex: 1;
    }

    .email-input input {
      border-radius: 9px 0 0 9px;
      border-right: none;
    }

    .email-domain {
      height: 44px;
      padding: 0 10px;
      background: #f0f2f5;
      border: 1.5px solid #e4e7ee;
      border-left: none;
      border-radius: 0 9px 9px 0;
      display: flex;
      align-items: center;
      font-size: 13px;
      color: #7f8795;
      white-space: nowrap;
    }

    .btn-sub {
      height: 44px;
      padding: 0 16px;
      border-radius: 9px;
      border: 1.5px solid #c8d4e8;
      background: #f0f4fb;
      color: #4a6fa5;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      font-family: inherit;
      white-space: nowrap;
    }

    .btn-sub:hover {
      background: #e7eefb;
    }

    .org-wrap {
      cursor: pointer;
    }

    .org-wrap input {
      cursor: pointer;
      padding-right: 34px;
    }

    .org-arrow {
      position: absolute;
      right: 12px;
      left: auto !important;
      font-size: 14px !important;
      color: #c3c7d0 !important;
      transition: transform .2s;
    }

    .org-dropdown {
      display: none;
      position: absolute;
      top: 72px;
      left: 0;
      right: 0;
      background: #fff;
      border: 1.5px solid #2d6be4;
      border-radius: 10px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.12);
      z-index: 100;
      overflow: hidden;
    }

    .org-search-box {
      padding: 10px 10px 6px;
    }

    .org-search-inner {
      position: relative;
    }

    .org-search-inner i {
      position: absolute;
      left: 10px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 14px;
      color: #aaa;
    }

    .org-search-inner input {
      width: 100%;
      height: 36px;
      border-radius: 7px;
      border: 1.5px solid #e8e9ed;
      background: #f5f6fa;
      padding: 0 10px 0 32px;
      font-size: 13px;
      outline: none;
      font-family: inherit;
    }

    .org-list {
      max-height: 180px;
      overflow-y: auto;
      padding: 4px 6px 8px;
    }

    .org-item {
      padding: 9px 10px;
      border-radius: 7px;
      font-size: 13px;
      color: #222;
      cursor: pointer;
    }

    .org-item:hover {
      background: #f0f4fb;
    }

    .agree-box {
      background: #f9fafc;
      border: 1px solid #eee;
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 16px;
      width: 100%;
    }

    .agree-line {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: #555;
      padding: 5px 0;
    }

    .agree-all {
      font-weight: 700;
      color: #222;
      padding-bottom: 10px;
      border-bottom: 1px solid #eee;
      margin-bottom: 8px;
    }

    .agree-line input {
      width: 18px;
      height: 18px;
      accent-color: #2d6be4;
    }

    .req {
      color: #2d6be4;
      font-size: 11px;
    }

    .btn-primary {
      width: 100%;
      height: 46px;
      border-radius: 10px;
      background: #1a2235;
      border: none;
      color: #fff;
      font-size: 14px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      cursor: pointer;
      margin-bottom: 14px;
      font-family: inherit;
    }

    .btn-primary:hover {
      background: #243040;
    }

    .login-link {
      font-size: 13px;
      color: #9aa0ad;
      text-align: center;
    }

    .login-link a {
      color: #2d6be4;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="brand">
    <div class="brand-title">FIDS</div>
    <span class="brand-line"></span>
    <div class="brand-desc">
      공공 쓰레기통 내 화재를 실시간으로<br>
      감지하고 관리하는 스마트 플랫폼
    </div>
  </div>

  <div class="page">
    <div class="form-title">회원가입</div>
    <div class="form-sub">관리자 포털 이용을 위해 계정을 생성하세요</div>

    <div class="grid2">
      <div class="field">
        <label>이름</label>
        <div class="input-wrap">
          <i class="ti ti-user"></i>
          <input id="mgr_name" type="text" placeholder="이름을 입력하세요">
        </div>
      </div>

      <div class="field">
        <label>소속 기관</label>
        <div class="input-wrap org-wrap" id="org-wrap">
          <i class="ti ti-building"></i>
          <input id="organization" type="text" placeholder="기관명을 검색하세요" readonly>
          <i class="ti ti-chevron-down org-arrow" id="org-arrow"></i>
        </div>

        <div class="org-dropdown" id="org-dropdown">
          <div class="org-search-box">
            <div class="org-search-inner">
              <i class="ti ti-search"></i>
              <input id="org-search" type="text" placeholder="기관명을 입력하세요">
            </div>
          </div>
          <div class="org-list" id="org-list"></div>
        </div>
      </div>
    </div>

    <div class="field">
      <label>이메일</label>
      <div class="email-row">
        <div class="email-input">
          <div class="input-wrap">
            <i class="ti ti-mail"></i>
            <input id="email_id" type="text" placeholder="이메일을 입력하세요">
          </div>
          <span class="email-domain">@korea.kr</span>
        </div>
        <button id="sendEmailBtn" class="btn-sub" type="button">인증받기</button>
      </div>
    </div>

    <div class="agree-box">
      <label class="agree-line agree-all">
        <input id="agree_all" type="checkbox" checked>
        전체 동의
      </label>
      <label class="agree-line">
        <input id="agree_terms" type="checkbox" checked>
        이용약관 동의 <span class="req">(필수)</span>
      </label>
      <label class="agree-line">
        <input id="agree_privacy" type="checkbox" checked>
        개인정보 처리방침 <span class="req">(필수)</span>
      </label>
    </div>

    <button id="nextBtn" class="btn-primary" type="button">
      <i class="ti ti-arrow-right"></i>
      다음
    </button>

    <div class="login-link">이미 계정이 있으신가요? <a href="/login">로그인</a></div>
  </div>

  <script>
    const ORG_LIST = [
      "서울특별시청",
      "부산광역시청",
      "대구광역시청",
      "인천광역시청",
      "광주광역시청",
      "대전광역시청",
      "울산광역시청",
      "세종특별자치시청",
      "경기도청",
      "강원특별자치도청",
      "충청북도청",
      "충청남도청",
      "전북특별자치도청",
      "전라남도청",
      "경상북도청",
      "경상남도청",
      "제주특별자치도청",
      "서울시 강남구청",
      "서울시 강북구청",
      "서울시 마포구청",
      "서울시 종로구청",
      "서울시 중구청",
      "서울시 송파구청",
      "서울시 용산구청",
      "국토교통부",
      "환경부",
      "행정안전부",
      "보건복지부",
      "소방청",
      "경찰청"
    ];

    const orgWrap = document.getElementById("org-wrap");
    const orgDropdown = document.getElementById("org-dropdown");
    const orgArrow = document.getElementById("org-arrow");
    const orgSearch = document.getElementById("org-search");
    const orgList = document.getElementById("org-list");
    const organization = document.getElementById("organization");

    function renderOrgList(items) {
      if (items.length === 0) {
        orgList.innerHTML = '<div class="org-item">검색 결과가 없습니다</div>';
        return;
      }

      orgList.innerHTML = items.map((name) => {
        return `<div class="org-item" data-name="${name}">${name}</div>`;
      }).join("");
    }

    function openOrgDropdown() {
      orgDropdown.style.display = "block";
      orgArrow.style.transform = "translateY(-50%) rotate(180deg)";
      renderOrgList(ORG_LIST);
      setTimeout(() => orgSearch.focus(), 50);
    }

    function closeOrgDropdown() {
      orgDropdown.style.display = "none";
      orgArrow.style.transform = "translateY(-50%)";
      orgSearch.value = "";
    }

    orgWrap.addEventListener("click", openOrgDropdown);

    orgSearch.addEventListener("input", () => {
      const keyword = orgSearch.value;
      const filtered = ORG_LIST.filter((name) => name.includes(keyword));
      renderOrgList(filtered);
    });

    orgList.addEventListener("click", (e) => {
      const item = e.target.closest(".org-item");
      if (!item || !item.dataset.name) return;

      organization.value = item.dataset.name;
      closeOrgDropdown();
    });

    document.addEventListener("click", (e) => {
      if (!orgWrap.contains(e.target) && !orgDropdown.contains(e.target)) {
        closeOrgDropdown();
      }
    });

    document.getElementById("agree_all").addEventListener("change", (e) => {
      document.getElementById("agree_terms").checked = e.target.checked;
      document.getElementById("agree_privacy").checked = e.target.checked;
    });

    let emailCodeSent = false;

    function validateJoinForm() {
      const mgrName = document.getElementById("mgr_name").value.trim();
      const orgName = organization.value.trim();
      const emailId = document.getElementById("email_id").value.trim();
      const agreeTerms = document.getElementById("agree_terms").checked;
      const agreePrivacy = document.getElementById("agree_privacy").checked;

      if (!mgrName) {
        alert("이름을 입력해주세요.");
        return null;
      }

      if (!orgName) {
        alert("소속 기관을 선택해주세요.");
        return null;
      }

      if (!emailId) {
        alert("이메일을 입력해주세요.");
        return null;
      }

      if (!agreeTerms || !agreePrivacy) {
        alert("필수 약관에 동의해주세요.");
        return null;
      }

      const mgrEmail = emailId + "@korea.kr";

      sessionStorage.setItem("mgr_name", mgrName);
      sessionStorage.setItem("organization", orgName);
      sessionStorage.setItem("mgr_email", mgrEmail);

      return mgrEmail;
    }

    async function sendEmailCode() {
      const mgrEmail = validateJoinForm();

      if (!mgrEmail) {
        return false;
      }

      const response = await fetch("/manager/email/send", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          mgr_email: mgrEmail
        })
      });

      const result = await response.text();
      alert(result);

      emailCodeSent = true;
      sessionStorage.setItem("email_code_sent", "Y");

      return true;
    }

    document.getElementById("sendEmailBtn").addEventListener("click", sendEmailCode);

    document.getElementById("nextBtn").addEventListener("click", () => {
      const mgrEmail = validateJoinForm();

      if (!mgrEmail) {
        return;
      }

      if (!emailCodeSent && sessionStorage.getItem("email_code_sent") !== "Y") {
        alert("먼저 인증받기 버튼을 눌러 인증번호를 발송해주세요.");
        return;
      }

      location.href = "/email-check";
    });
  </script>
</body>
</html>
