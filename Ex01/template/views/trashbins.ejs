ze:11px;fill:#d97706;font-weight:800}.alert-item:not(.read) .alert-text strong{color:#111827!important;font-weight:800!important}.alert-item:not(.read) .alert-text span{color:#1f2937!important}.alert-item:not(.read) .alert-text small,.alert-item:not(.read) .alert-time{color:#6b7280!important}.all-alert-row:not(.read) strong{color:#111827!important;font-weight:800!important}.all-alert-row:not(.read) span,.all-alert-row:not(.read) p,.all-alert-row:not(.read) time{color:#1f2937!important}</style></head>
<body>
<div class="sidebar"><div class="sb-logo"><div class="sb-logo-title"><span></span>FIDS</div><div class="sb-logo-sub2">쓰레기통 화재 감지 시스템</div><div class="sb-logo-sub">관리자 대시보드</div></div><div class="sb-nav"><div class="nav-item" onclick="location.href='/dashboard'"><i class="ti ti-home"></i>대시보드</div><div class="nav-item active" onclick="location.href='/trashbins'"><i class="ti ti-trash"></i>쓰레기통 관리</div><div class="nav-item" onclick="location.href='/realtime'"><i class="ti ti-chart-line"></i>실시간 모니터링</div><div class="nav-item" onclick="location.href='/alert'"><i class="ti ti-bell"></i>알림 기록</div><div class="nav-item operator-menu" onclick="location.href='/admin/approval'"><i class="ti ti-user-check"></i>관리자 승인 관리</div><div class="nav-item" onclick="location.href='/settings'"><i class="ti ti-settings"></i>설정</div><div class="nav-item" onclick="location.href='/'"><i class="ti ti-home-2"></i>메인페이지</div></div><div class="sb-bottom"><div class="sb-user"><div class="sb-avatar"><i class="ti ti-user"></i></div><div><div id="userName" class="sb-user-name">관리자</div><div id="userEmail" class="sb-user-email">admin@korea.kr</div></div></div><div id="logoutBtn" class="sb-logout"><i class="ti ti-logout"></i>로그아웃</div></div></div>
<div class="main"><div class="topbar"><div class="topbar-title">쓰레기통 관리</div><div class="topbar-right"><i class="ti ti-calendar"></i><span id="nowText"></span><div class="alert-area"><button class="alert-button" id="alertButton"><i class="ti ti-bell"></i><span class="alert-dot" id="alertDot"></span></button><div class="alert-dropdown" id="alertDropdown"><div class="alert-head"><strong>알림</strong><button id="readAllBtn">모두 읽음</button></div><div class="alert-list" id="alertList"></div><button class="alert-more" id="openAllAlertsBtn">전체 알림 보기 →</button></div></div><button class="btn-add" onclick="openRegisterModal()"><i class="ti ti-plus"></i>신규 등록</button></div></div><div class="content"><div class="stat-row"><div class="stat-card total" onclick="filterByStatus('')"><div><div class="stat-label">전체 등록</div><div><span class="stat-num" id="totalCount">0</span><span class="stat-unit">개</span></div><div class="stat-sub">등록된 쓰레기통</div></div><div class="stat-icon"><i class="ti ti-trash"></i></div></div><div class="stat-card danger" onclick="filterByStatus('danger')"><div><div class="stat-label">위험 상태</div><div><span class="stat-num" id="dangerCount">0</span><span class="stat-unit">개</span></div><div class="stat-sub">즉시 확인 필요</div></div><div class="stat-icon"><i class="ti ti-flame"></i></div></div><div class="stat-card warn" onclick="filterByStatus('warning')"><div><div class="stat-label">주의 상태</div><div><span class="stat-num" id="warningCount">0</span><span class="stat-unit">개</span></div><div class="stat-sub">상태 관찰 필요</div></div><div class="stat-icon"><i class="ti ti-alert-triangle"></i></div></div><div class="stat-card good" onclick="filterByStatus('normal')"><div><div class="stat-label">정상 상태</div><div><span class="stat-num" id="normalCount">0</span><span class="stat-unit">개</span></div><div class="stat-sub">기본 운영 가능</div></div><div class="stat-icon"><i class="ti ti-check"></i></div></div></div><div class="panel"><div class="panel-head"><span class="panel-title">등록된 쓰레기통 목록</span><div class="filters"><div class="search-box"><i class="ti ti-search"></i><input id="searchInput" placeholder="쓰레기통 ID, 설치 위치 검색..." oninput="renderTable()"></div><select class="sel" id="statusFilter" onchange="renderTable()"><option value="">전체 상태</option><option value="danger">위험</option><option value="warning">주의</option><option value="normal">정상</option></select></div></div><table><thead><tr><th>쓰레기통 ID</th><th>설치 위치</th><th>상태</th><th>설치일</th><th>관리자</th><th>관리</th></tr></thead><tbody id="trashbinBody"></tbody></table><div class="empty" id="emptyText" style="display:none">등록된 쓰레기통이 없습니다.</div></div></div></div>
<div class="all-alert-overlay" id="allAlertOverlay"><div class="all-alert-modal"><div class="all-alert-header"><div><h2>전체 알림</h2><p>최근 감지된 알림 내역입니다.</p></div><button id="closeAllAlertsBtn">×</button></div><div class="all-alert-list" id="allAlertList"></div></div></div>
<div class="modal-overlay" id="detailModal"><div class="detail-modal"><div class="detail-head"><strong>쓰레기통 상세보기</strong><button type="button" onclick="closeDetailModal()">×</button></div><div class="detail-body"><div class="detail-title-row"><div><div class="detail-name" id="detailName">-</div><div class="detail-region" id="detailRegion">-</div></div><span class="detail-status normal" id="detailStatus">정상</span></div><div class="detail-info"><div><div class="detail-label">설치 담당자</div><div class="detail-value" id="detailManager">-</div></div><div><div class="detail-label">연락처</div><div class="detail-value" id="detailPhone">-</div></div><div><div class="detail-label">설치일</div><div class="detail-value" id="detailInstalled">-</div></div><div><div class="detail-label">마지막 업데이트</div><div class="detail-value" id="detailUpdated">-</div></div><div><div class="detail-label">배터리</div><div class="detail-value" id="detailBattery">-</div></div><div><div class="detail-label">불꽃 감지</div><div class="detail-value" id="detailFlame">0</div></div><div><div class="detail-label">통신</div><div class="detail-value" id="detailNetwork">-</div></div></div><div class="chart-box"><div class="chart-title">연기감지값 추이 (최근 12회)</div><svg class="smoke-chart" id="smokeChart" viewBox="0 0 460 150" preserveAspectRatio="none"></svg></div></div></div></div><div class="modal-overlay" id="registerModal"><div class="modal register"><div class="modal-head"><strong>신규 등록</strong><button onclick="closeRegisterModal()">×</button></div><div class="modal-body"><div class="form-grid"><div><label>쓰레기통 ID</label><input id="binDisplayId" placeholder="예) #09"></div><div><label>설치 위치명</label><input id="binPlaceName" placeholder="예) 공원 입구"></div><div><label>시/도</label><input id="binCity" placeholder="예) 서울시"></div><div><label>구/군</label><input id="binDistrict" placeholder="예) 강남구"></div><div><label>설치 담당자</label><input id="managerNameInput" placeholder="이름 입력"></div><div><label>연락처</label><input id="managerPhoneInput" placeholder="010-0000-0000"></div><div class="full"><label>설치일</label><input id="installedAt" type="date"></div></div><input id="networkStatus" type="hidden" value="1"><div class="error" id="formError"></div><div class="modal-actions"><button class="btn-cancel" onclick="closeRegisterModal()">취소</button><button class="btn-save" onclick="createTrashbin()">등록하기</button></div></div></div></div>
<script>
const FIDS_ALERT_READ_KEY="fids_alerts_read_all";(function(){try{const n=performance.getEntriesByType("navigation")[0];if(n&&n.type==="reload"){sessionStorage.removeItem(FIDS_ALERT_READ_KEY);}}catch(e){}})();function fidsApplyAlertReadState(rows){const list=Array.isArray(rows)?rows:[];if(sessionStorage.getItem(FIDS_ALERT_READ_KEY)==="Y"){return list.map(row=>({...row,is_received:"Y"}));}return list;}function fidsMarkAlertsRead(){sessionStorage.setItem(FIDS_ALERT_READ_KEY,"Y");}function fidsAlertsAreRead(){return sessionStorage.getItem(FIDS_ALERT_READ_KEY)==="Y";}function fidsClearReadOnReload(){try{const n=performance.getEntriesByType("navigation")[0];if(n&&n.type==="reload"){sessionStorage.removeItem(FIDS_ALERT_READ_KEY);}}catch(e){}}

let trashbins=[],alerts=[];const role=sessionStorage.getItem("role"),mgrName=sessionStorage.getItem("mgr_name"),mgrEmail=sessionStorage.getItem("mgr_email");if(!role){alert("로그인이 필요합니다.");location.href="/login"}userName.textContent=mgrName||"관리자";userEmail.textContent=mgrEmail||"";logoutBtn.onclick=()=>{sessionStorage.clear();alert("\uB85C\uADF8\uC544\uC6C3\uB418\uC5C8\uC2B5\uB2C8\uB2E4.");location.replace("/")};function tick(){const n=new Date();nowText.textContent=n.getFullYear()+"."+String(n.getMonth()+1).padStart(2,"0")+"."+String(n.getDate()).padStart(2,"0")+" "+String(n.getHours()).padStart(2,"0")+":"+String(n.getMinutes()).padStart(2,"0")+":"+String(n.getSeconds()).padStart(2,"0")}function statusOf(r){if(Number(r.network_status)===0)return"offline";if(r.alert_type==="danger")return"danger";if(r.alert_type==="warning")return"warning";return"normal"}function statusText(s){return s==="danger"?"위험":s==="warning"?"주의":s==="offline"?"오프라인":"정상"}function rank(s){return s==="danger"?1:s==="warning"?2:s==="normal"?3:4}function fdate(v){return v?new Date(v).toLocaleDateString("ko-KR",{year:"numeric",month:"2-digit",day:"2-digit"}):"-"}function ftime(v){return v?new Date(v).toLocaleTimeString("ko-KR",{hour:"2-digit",minute:"2-digit",second:"2-digit"}):"-"}function region(loc){const p=String(loc||"").trim().split(/\s+/);return p.length>=2?p[0]+" "+p[1]:"위치 정보"}function filterByStatus(status){statusFilter.value=status;renderTable()}function renderTable(){const kw=searchInput.value.trim().toLowerCase(),sf=statusFilter.value;const rows=trashbins.filter(r=>{const s=statusOf(r),t=(r.bin_id+" "+(r.bin_loc||"")+" "+(r.mgr_name||"")).toLowerCase();return(!kw||t.includes(kw))&&(!sf||s===sf)}).sort((a,b)=>rank(statusOf(a))-rank(statusOf(b))||Number(a.bin_id)-Number(b.bin_id));emptyText.style.display=rows.length?"none":"block";trashbinBody.innerHTML=rows.map(r=>{const s=statusOf(r);return `<tr><td><span class="bin-id">#${String(r.bin_id).padStart(2,"0")}</span></td><td><div class="loc-main">${r.bin_loc||"-"}</div><div class="loc-sub">${region(r.bin_loc)}</div></td><td><span class="badge ${s}">${statusText(s)}</span></td><td><span class="date-text">${fdate(r.installed_at)}</span></td><td>${r.mgr_name||"관리자"}</td><td><div class="action-buttons"><button class="icon-btn" onclick="openDetailModal(${r.bin_id})" title="상세보기"><i class="ti ti-eye"></i></button><button class="icon-btn delete" onclick="deleteTrashbin(${r.bin_id})" title="삭제"><i class="ti ti-trash"></i></button></div></td></tr>`}).join("");totalCount.textContent=trashbins.length;dangerCount.textContent=trashbins.filter(r=>statusOf(r)==="danger").length;warningCount.textContent=trashbins.filter(r=>statusOf(r)==="warning").length;normalCount.textContent=trashbins.filter(r=>statusOf(r)==="normal").length}function atitle(t){return t==="danger"?"위험 감지":t==="warning"?"주의 감지":"정상 복귀"}function aicon(t){return t==="danger"?"ti-flame":t==="warning"?"ti-alert-triangle":"ti-check"}function renderAlerts(){alertDot.classList.toggle("hide", fidsAlertsAreRead() || !alerts.some(a=>a.alert_type==="danger"));const dangerAlerts=alerts.filter(a=>a.alert_type==="danger");alertList.innerHTML=dangerAlerts.slice(0,5).map(a=>`<div class="alert-item ${a.alert_type} ${fidsAlertsAreRead()?"read":""}"><div class="alert-icon"><i class="ti ${aicon(a.alert_type)}"></i></div><div class="alert-text"><strong>${atitle(a.alert_type)}</strong><span>#${a.bin_id} ${a.bin_loc||""}</span><small>${a.alert_msg||"센서 상태 정상"}</small></div><span class="alert-time">${ftime(a.alerted_at)}</span></div>`).join("");allAlertList.innerHTML=dangerAlerts.map(a=>`<div class="all-alert-row ${a.alert_type} ${fidsAlertsAreRead()?"read":""}"><div><strong>${atitle(a.alert_type)}</strong><span>#${a.bin_id} ${a.bin_loc||""}</span></div><p>${a.alert_msg||"센서 상태 정상"}</p><time>${ftime(a.alerted_at)}</time></div>`).join("")}async function loadAlerts(){const r=await fetch("/alerts/list");alerts=fidsApplyAlertReadState(await r.json());renderAlerts()}async function loadTrashbins(){const r=await fetch("/trashbins/list");trashbins=await r.json();renderTable();await loadAlerts()}function openRegisterModal(){registerModal.classList.add("open")}function closeRegisterModal(){registerModal.classList.remove("open");formError.style.display="none";[binDisplayId,binPlaceName,binCity,binDistrict,managerNameInput,managerPhoneInput,installedAt].forEach(el=>el.value="")}async function createTrashbin(){const city=binCity.value.trim(),district=binDistrict.value.trim(),place=binPlaceName.value.trim();const mgrId=sessionStorage.getItem("user_id")||sessionStorage.getItem("mgr_id")||"";if(!city||!district||!place||!installedAt.value){formError.textContent="설치 위치명, 시/도, 구/군, 설치일을 입력해주세요.";formError.style.display="block";return}const binLoc=`${city} ${district} ${place}`;const r=await fetch("/trashbins",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({bin_loc:binLoc,installed_at:installedAt.value,mgr_id:mgrId,network_status:networkStatus.value,manager_name:managerNameInput.value.trim(),manager_phone:managerPhoneInput.value.trim()})});const j=await r.json();if(!r.ok){formError.textContent=j.message||"등록 실패";formError.style.display="block";return}closeRegisterModal();loadTrashbins()}async function deleteTrashbin(id){if(!confirm("정말 삭제하시겠습니까?"))return;const r=await fetch("/trashbins/"+id,{method:"DELETE"});const j=await r.json();if(!r.ok){alert(j.message||"삭제 실패");return}loadTrashbins()}function parseSmoke(msg){const m=String(msg||"").match(/\uC5F0\uAE30\s*\uAC10\uC9C0\uAC12\s*(\d+)|\uC5F0\uAE30[^0-9]*(\d+)/);return m?Number(m[1]||m[2]):12}function parseTemp(msg){const m=String(msg||"").match(/\uC628\uB3C4\s*([0-9.]+)|([0-9.]+)\s*(?:\u00B0)?C/);return m?Number(m[1]||m[2]):28.4}function parseFlame(row){if(statusOf(row)==="danger")return 1;const m=String(row.alert_msg||"").match(/\uBD88\uAF43\s*\uAC10\uC9C0\s*(0|1)/);return m?Number(m[1]):0}function batteryText(r){const s=statusOf(r);return s==="danger"||s==="warning"?"저전압":"정상"}function networkText(r){if(Number(r.network_status)===0)return"Wi-Fi 연결 끊김 / LTE 끊김";const smoke=parseSmoke(r.alert_msg);if(smoke>=300)return"Wi-Fi -79 dBm / LTE 끊김";if(smoke>=100)return"Wi-Fi -71 dBm / LTE 정상";return"Wi-Fi -52 dBm / LTE 정상"}function smokeSeries(base){const values=[base-300,base-270,base-230,base-190,base-140,base-90,base-55,base-35,base-18,base,base,base].map(v=>Math.max(10,Math.round(v)));return values}function renderSmokeChart(base){const svg=document.getElementById("smokeChart");const vals=smokeSeries(base);const max=400,min=0,w=420,h=112,ox=28,oy=12;const x=i=>ox+(w/(vals.length-1))*i;const y=v=>oy+h-((v-min)/(max-min))*h;const points=vals.map((v,i)=>`${x(i)},${y(v)}`).join(" ");const area=`${ox},${oy+h} ${points} ${ox+w},${oy+h}`;svg.innerHTML=`<line class="chart-axis" x1="${ox}" y1="${y(400)}" x2="${ox+w}" y2="${y(400)}"></line><line class="chart-axis" x1="${ox}" y1="${y(300)}" x2="${ox+w}" y2="${y(300)}"></line><line class="chart-axis" x1="${ox}" y1="${y(200)}" x2="${ox+w}" y2="${y(200)}"></line><line class="chart-axis" x1="${ox}" y1="${y(100)}" x2="${ox+w}" y2="${y(100)}"></line><line class="chart-warning" x1="${ox}" y1="${y(100)}" x2="${ox+w}" y2="${y(100)}"></line><line class="chart-danger" x1="${ox}" y1="${y(300)}" x2="${ox+w}" y2="${y(300)}"></line><polygon class="chart-area" points="${area}"></polygon><polyline class="chart-line" points="${points}"></polyline>${vals.map((v,i)=>`<circle class="chart-point" cx="${x(i)}" cy="${y(v)}" r="4"></circle>`).join("")}<text class="chart-text" x="2" y="${y(400)+4}">400</text><text class="chart-danger-text" x="2" y="${y(300)+4}">300</text><text class="chart-warning-text" x="2" y="${y(100)+4}">100</text><text class="chart-danger-text" x="${ox+w-8}" y="${y(300)-7}">위험</text><text class="chart-warning-text" x="${ox+w-8}" y="${y(100)-7}">주의</text><text class="chart-danger-text" x="${Math.min(ox+w-20,x(vals.length-1)-12)}" y="${Math.max(16,y(vals[vals.length-1])-14)}">${vals[vals.length-1]}</text><text class="chart-text" x="${ox}" y="145">12회 전</text><text class="chart-text" x="${ox+w-24}" y="145">현재</text>`}function openDetailModal(id){const r=trashbins.find(item=>Number(item.bin_id)===Number(id));if(!r)return;const s=statusOf(r);detailName.textContent="#"+String(r.bin_id).padStart(2,"0")+" — "+(r.bin_loc||"위치 미등록");detailRegion.textContent=region(r.bin_loc);detailStatus.className="detail-status "+s;detailStatus.textContent=statusText(s);detailManager.textContent=r.mgr_name||"관리자";detailPhone.textContent=r.mgr_phone||"-";detailInstalled.textContent=fdate(r.installed_at);detailUpdated.textContent=ftime(r.alerted_at)||"-";detailBattery.textContent=batteryText(r);detailFlame.textContent=parseFlame(r);detailNetwork.textContent=networkText(r);renderSmokeChart(parseSmoke(r.alert_msg));detailModal.classList.add("open")}function closeDetailModal(){detailModal.classList.remove("open")}alertButton.onclick=e=>{e.stopPropagation();alertDropdown.classList.toggle("open")};readAllBtn.onclick=async()=>{fidsMarkAlertsRead();await fetch("/alerts/read-all",{method:"POST"});await loadAlerts();};openAllAlertsBtn.onclick=()=>{alertDropdown.classList.remove("open");allAlertOverlay.classList.add("open")};closeAllAlertsBtn.onclick=()=>allAlertOverlay.classList.remove("open");document.onclick=e=>{if(!e.target.closest(".alert-area"))alertDropdown.classList.remove("open")};tick();setInterval(tick,1000);loadTrashbins();
</script><script src="/js/fire-alert.js"></script><script>document.querySelectorAll(".operator-menu").forEach((item)=>{item.style.display=sessionStorage.getItem("role")==="operator"?"flex":"none";});</script>
<script>
  window.addEventListener("pageshow", function () {
    if (!sessionStorage.getItem("role")) {
      location.replace("/");
    }
  });
</script>
</body></html>









