ex;justify-content:space-between;padding:18px 22px;border-bottom:1px solid #f1f5f9}.modal-head button{border:0;background:transparent;font-size:22px;color:#94a3b8}.modal-body{padding:22px}.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}label{display:block;font-size:12px;font-weight:700;color:#475569;margin-bottom:6px}.modal input,.modal select{width:100%;height:42px;border-radius:9px;border:1.5px solid #e2e8f0;background:#fafafa;padding:0 12px;font-size:13px}.error{display:none;color:#dc2626;font-size:12px}.modal-actions{display:flex;gap:8px;margin-top:20px}.modal-actions button{height:44px;border-radius:9px;font-size:13px;font-weight:700;cursor:pointer}.btn-cancel{flex:1;border:1.5px solid #e2e8f0;background:#fff;color:#64748b}.btn-save{flex:2;border:0;background:#1e293b;color:#fff}
