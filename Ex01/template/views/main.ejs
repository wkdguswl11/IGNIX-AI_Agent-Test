        모달 팝업
================================ -->
<div class="modal-overlay" id="modal" onclick="closeModal()">
    <div class="modal-box" onclick="event.stopPropagation()">

        <!-- 닫기 버튼 -->
        <button class="modal-close" onclick="closeModal()">✕</button>

        <!-- 내용 -->
        <div id="modal-content"></div>

    </div>
</div>

<!-- ===============================
        모달 스크립트
================================ -->
<script>
    function openModal(type) {
        const contents = {
            terms: `
                <h2>이용약관</h2>
                <p>FIDS 서비스를 이용해 주셔서 감사합니다.</p>
                <p>본 약관은 IGNIX가 제공하는 FIDS 서비스 이용에 관한 조건 및 절차를 규정합니다.</p>
            `,
            privacy: `
                <h2>개인정보처리방침</h2>
                <p>IGNIX는 이용자의 개인정보를 중요시하며, 개인정보 보호법에 따라 이용자의 개인정보를 보호하고 있습니다.</p>
                <p>수집하는 개인정보는 서비스 제공 목적으로만 사용됩니다.</p>
            `,
            contact: `
                <h2>문의하기</h2>
                <p>이메일 : <a href="mailto:operator@korea.kr">operator@korea.kr</a></p>
                <p>업무시간 : 평일 09:00 ~ 18:00</p>
            `
        };
        document.getElementById('modal-content').innerHTML = contents[type];
        document.getElementById('modal').style.display = 'flex';
    }

    function closeModal() {
        document.getElementById('modal').style.display = 'none';
    }

    function renderMainAuth() {
        const authArea = document.getElementById("authArea");
        if (!authArea) return;

        const email = sessionStorage.getItem("mgr_email");
        const name = sessionStorage.getItem("mgr_name") || "관리자";

        if (!email) return;

        authArea.innerHTML = `
            <button class="login" type="button">${name}</button>
            <button class="sigup" type="button" onclick="logoutFromMain()">로그아웃</button>
        `;
    }


    function logoutFromMain() {
        sessionStorage.clear();
        alert("로그아웃하였습니다.");
        location.replace("/");
    }
    renderMainAuth();
</script>

</body>
</html>


