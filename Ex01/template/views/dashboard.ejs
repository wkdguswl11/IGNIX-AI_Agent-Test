<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1280">
  <title>대시보드 - FIDS</title>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
  <link rel="stylesheet" href="/css/fire-alert.css">

  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: "Pretendard", "Apple SD Gothic Neo", Arial, sans-serif;
      background: #f5f6fa;
      display: flex;
      height: 100vh;
      overflow: hidden;
      color: #1a1a2e;
    }
    .sidebar { width: 220px; flex-shrink: 0; background: #1a2235; display: flex; flex-direction: column; height: 100vh; }
    .sb-logo { padding: 20px 18px 16px; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .sb-logo-title { font-size: 16px; font-weight: 700; color: #fff; line-height: 1.2; letter-spacing: .5px; }
    .sb-logo-title span { display: inline-block; width: 3px; height: 16px; background: #2d6be4; border-radius: 2px; margin-right: 8px; vertical-align: middle; }
    .sb-logo-sub { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px; }
    .sb-logo-sub2 { font-size: 10px; color: rgba(255,255,255,0.3); margin-top: 3px; }
    .sb-nav { padding: 14px 10px; flex: 1; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; font-size: 13px; color: rgba(255,255,255,0.55); cursor: pointer; margin-bottom: 2px; }
    .nav-item.active { background: rgba(255,255,255,0.10); color: #fff; }
    .nav-item i { font-size: 17px; }
    .sb-bottom { padding: 14px 10px; border-top: 1px solid rgba(255,255,255,0.08); }
    .sb-user { display: flex; align-items: center; gap: 10px; padding: 10px 12px; margin-bottom: 2px; }
    .sb-avatar { width: 32px; height: 32px; border-radius: 50%; background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .sb-avatar i { font-size: 15px; color: rgba(255,255,255,0.7); }
    .sb-user-name { font-size: 12px; font-weight: 600; color: #fff; }
    .sb-user-email { font-size: 10px; color: rgba(255,255,255,0.4); margin-top: 1px; }
    .sb-logout { display: flex; align-items: center; gap: 10px; padding: 9px 12px; font-size: 13px; color: rgba(255,255,255,0.4); cursor: pointer; border-radius: 8px; }
    .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    .topbar { background: #fff; padding: 0 28px; height: 60px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #e8e9ed; flex-shrink: 0; }
    .topbar-title { font-size: 20px; font-weight: 700; color: #1a1a2e; }
    .topbar-right { display: flex; align-items: center; gap: 14px; font-size: 12px; color: #999; }
    .refresh-btn { display: flex; align-items: center; gap: 5px; padding: 7px 14px; border-radius: 8px; border: 1px solid #e0e0e0; background: #fff; font-size: 12px; color: #555; cursor: pointer; font-family: inherit; }
    .content { flex: 1; overflow-y: auto; padding: 22px 28px; }
    .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 18px; }
    .stat-card { background: #fff; border-radius: 12px; padding: 20px 22px; border: 1px solid #e8e9ed; display: flex; align-items: center; justify-content: space-between; cursor: pointer; }
    .stat-label { font-size: 12px; font-weight: 700; margin-bottom: 8px; }
    .stat-num { font-size: 30px; font-weight: 800; color: #1a1a2e; line-height: 1; }
    .stat-unit { font-size: 15px; color: #888; margin-left: 4px; }
    .stat-sub { font-size: 11px; color: #bbb; margin-top: 6px; }
    .stat-pct { font-size: 13px; font-weight: 700; margin-top: 6px; }
    .stat-icon { width: 52px; height: 52px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; }
    .total .stat-label { color: #378ADD; } .total .stat-icon { background: #EBF4FF; color: #378ADD; }
    .good .stat-label, .good .stat-num { color: #22a06b; } .good .stat-icon { background: #e6f7f0; color: #22a06b; } .good .stat-pct { color: #22a06b; }
    .warn .stat-label, .warn .stat-num { color: #d97706; } .warn .stat-icon { background: #FEF3C7; color: #d97706; } .warn .stat-pct { color: #d97706; }
    .danger .stat-label, .danger .stat-num { color: #dc2626; } .danger .stat-icon { background: #FEE2E2; color: #dc2626; } .danger .stat-pct { color: #dc2626; }
    .mid-row { display: grid; grid-template-columns: 1fr 340px; gap: 16px; margin-bottom: 16px; }
    .panel { background: #fff; border-radius: 12px; border: 1px solid #e8e9ed; padding: 18px 22px; }
    .panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .panel-title { font-size: 15px; font-weight: 700; color: #1a1a2e; }
    .panel-more { font-size: 12px; color: #2d6be4; cursor: pointer; }
    .filter-toggle { display: flex; gap: 4px; background: #f5f6fa; border-radius: 8px; padding: 3px; }
    .ft-btn { padding: 4px 12px; border-radius: 6px; font-size: 12px; font-weight: 700; cursor: pointer; border: none; background: transparent; color: #aaa; transition: all .15s; font-family: inherit; }
    .ft-btn.active-all { background: #fff; color: #1a1a2e; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
    .ft-btn.active-danger { background: #FEE2E2; color: #dc2626; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
    .ft-btn.active-warn { background: #FEF3C7; color: #d97706; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
    .ft-btn.active-good { background: #e6f7f0; color: #14734a; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    thead th { text-align: center; color: #bbb; font-weight: 600; padding: 0 10px 10px; border-bottom: 1px solid #f0f0f0; }
    tbody td { padding: 11px 10px; border-bottom: 1px solid #f5f5f5; color: #444; vertical-align: middle; text-align: center; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr.danger-row { background: #fff8f8; }
    tbody tr.danger-row td { color: #dc2626; }
    tbody tr.warn-row { background: #fffbeb; }
    tbody tr.warn-row td { color: #b45309; }
    tbody tr.hidden { display: none; }
    tbody tr.focus-bin { outline: 3px solid #ef4444; outline-offset: -3px; background: #fff1f2; }
    .badge { display: inline-flex; align-items: center; gap: 3px; padding: 3px 10px; border-radius: 99px; font-size: 12px; font-weight: 700; }
    .badge.ok { background: #e6f7f0; color: #14734a; } .badge.warn { background: #FEF3C7; color: #92400e; } .badge.danger { background: #FEE2E2; color: #991b1b; }
    .more-row { text-align: center; padding: 10px; font-size: 12px; color: #999; cursor: pointer; border-top: 1px solid #f0f0f0; margin-top: 6px; }
    .side-alert-list { display: flex; flex-direction: column; }
    .side-alert-item { display: flex; align-items: flex-start; gap: 10px; padding: 11px 0; border-bottom: 1px solid #f5f5f5; }
    .side-alert-item:last-child { border-bottom: none; }
    .adot { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; margin-top: 1px; }
    .adot.d { background: #FEE2E2; color: #dc2626; } .adot.w { background: #FEF3C7; color: #d97706; } .adot.o { background: #e6f7f0; color: #22a06b; }
    .at { font-size: 12px; font-weight: 700; margin-bottom: 2px; } .at.d { color: #dc2626; } .at.w { color: #d97706; } .at.o { color: #22a06b; }
    .aloc { font-size: 13px; font-weight: 600; color: #222; margin-bottom: 2px; }
    .adesc { font-size: 11px; color: #aaa; }
    .atime { font-size: 11px; color: #ccc; margin-left: auto; white-space: nowrap; padding-top: 2px; text-align: right; line-height: 1.6; }
    .bottom-bar { background: #fff; border-radius: 12px; border: 1px solid #e8e9ed; padding: 16px 28px; display: flex; align-items: center; justify-content: space-around; }
    .bot-item { display: flex; align-items: center; gap: 10px; }
    .bot-icon { font-size: 24px; color: #bbb; }
    .bot-label { font-size: 11px; color: #bbb; }
    .bot-val { font-size: 14px; font-weight: 700; margin-top: 2px; }
    .bot-val.ok { color: #22a06b; } .bot-val.blue { color: #2d6be4; }
    .sep { width: 1px; height: 36px; background: #f0f0f0; }

    .alert-area { position: relative; }
    .alert-button { position: relative; width: 44px; height: 44px; border: 1px solid #e5e7eb; border-radius: 50%; background: #fff; cursor: pointer; font-size: 18px; display: grid; place-items: center; color: #1f2937; }
    .alert-dot { position: absolute; top: 9px; right: 10px; width: 8px; height: 8px; background: #ef4444; border-radius: 50%; border: 2px solid #fff; }
    .alert-dot.hide { display: none; }
    .alert-dropdown { display: none; position: absolute; top: 52px; right: 0; width: 330px; max-height: 420px; background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; box-shadow: 0 18px 45px rgba(15, 23, 42, 0.18); overflow: hidden; z-index: 50; }
    .alert-dropdown.open { display: block; }
    .alert-head { display: flex; justify-content: space-between; align-items: center; padding: 16px 18px; border-bottom: 1px solid #eef2f7; }
    .alert-head button { border: 0; background: none; color: #2563eb; font-size: 13px; cursor: pointer; }
    .alert-list { max-height: 300px; overflow-y: auto; }
    .alert-item { display: grid; grid-template-columns: 42px 1fr 56px; gap: 10px; padding: 14px 16px; border-bottom: 1px solid #f1f5f9; }
    .alert-item.danger { background: #fff5f5; }
    .alert-icon { width: 34px; height: 34px; border-radius: 50%; display: grid; place-items: center; font-size: 15px; }
    .alert-item.danger .alert-icon { background: #fee2e2; color: #ef4444; }
    .alert-item.warning .alert-icon { background: #fef3c7; color: #f59e0b; }
    .alert-item.success .alert-icon { background: #d1fae5; color: #10b981; }
    .alert-text { display: flex; flex-direction: column; gap: 4px; }
    .alert-text strong { font-size: 14px; }
    .alert-text span { font-size: 13px; color: #111827; }
    .alert-text small { font-size: 12px; color: #9ca3af; }
    .alert-time { font-size: 12px; color: #c0c4cc; }
    .alert-more { width: 100%; height: 42px; border: 0; background: #fff; color: #2563eb; font-weight: 600; cursor: pointer; }

    .all-alert-overlay { display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.45); z-index: 9000; align-items: center; justify-content: center; }
    .all-alert-overlay.open { display: flex; }
    .all-alert-modal { width: min(720px, calc(100% - 32px)); max-height: 80vh; background: #fff; border-radius: 16px; box-shadow: 0 24px 70px rgba(15, 23, 42, 0.25); overflow: hidden; }
    .all-alert-header { display: flex; align-items: center; justify-content: space-between; padding: 22px 24px; border-bottom: 1px solid #e5e7eb; }
    .all-alert-header h2 { margin: 0; font-size: 22px; }
    .all-alert-header p { margin: 6px 0 0; color: #6b7280; font-size: 14px; }
    .all-alert-header button { width: 36px; height: 36px; border: 0; border-radius: 50%; background: #f3f4f6; font-size: 24px; cursor: pointer; }
    .all-alert-list { max-height: 58vh; overflow-y: auto; padding: 10px; }
    .all-alert-row { display: grid; grid-template-columns: 180px 1fr 90px; gap: 16px; align-items: center; padding: 16px; border-radius: 12px; border-bottom: 1px solid #f1f5f9; }
    .all-alert-row.danger { background: #fff5f5; }
    .all-alert-row.warning { background: #fffbeb; }
    .all-alert-row.success { background: #ecfdf5; }
    .all-alert-row strong { display: block; font-size: 15px; }
    .all-alert-row span, .all-alert-row p, .all-alert-row time { color: #6b7280; font-size: 14px; }
    .all-alert-row p { margin: 0; }
      .alert-item.read { }
    .alert-item.read .alert-text strong { font-weight: 500; color: #6b7280; }
    .alert-item.read .alert-text span, .alert-item.read .alert-text small, .alert-item.read .alert-time { color: #b0b7c3; }
    .alert-item.read .alert-icon { }
    .all-alert-row.read { }
    .all-alert-row.read strong { font-weight: 500; color: #9ca3af; }
    .side-alert-item.read { opacity: .55; } .side-alert-item.read .at { font-weight: 500; color: #9ca3af; } .side-alert-item.read .adot { filter: grayscale(1); opacity: .55; }
  .operator-menu{display:none}</style>
</head>
<body>
  <div class="sidebar">
    <div class="sb-logo">
      <div class="sb-logo-title"><span></span>FIDS</div>
      <div class="sb-logo-sub2">쓰레기통 화재 감지 시스템</div>
      <div class="sb-logo-sub">관리자 대시보드</div>
    </div>

    <div class="sb-nav">
      <div class="nav-item active" onclick="location.href='/dashboard'"><i class="ti ti-home"></i>대시보드</div>
      <div class="nav-item" onclick="location.href='/trashbins'"><i class="ti ti-trash"></i>쓰레기통 관리</div>
      <div class="nav-item" onclick="location.href='/realtime'"><i class="ti ti-chart-line"></i>실시간 모니터링</div>
      <div class="nav-item" onclick="location.href='/alert'"><i class="ti ti-bell"></i>알림 기록</div>
      <div class="nav-item operator-menu" onclick="location.href='/admin/approval'"><i class="ti ti-user-check"></i>관리자 승인 관리</div><div class="nav-item" onclick="location.href='/settings'"><i class="ti ti-settings"></i>설정</div><div class="nav-item" onclick="location.href='/'"><i class="ti ti-home-2"></i>메인페이지</div>
    </div>

    <div class="sb-bottom">
      <div class="sb-user">
        <div class="sb-avatar"><i class="ti ti-user"></i></div>
        <div>
          <div id="userName" class="sb-user-name">관리자</div>
          <div id="userEmail" class="sb-user-email">admin@korea.kr</div>
        </div>
      </div>
      <div id="logoutBtn" class="sb-logout"><i class="ti ti-logout"></i>로그아웃</div>
    </div>
  </div>

  <div class="main">
    <div class="topbar">
      <div class="topbar-title">대시보드</div>
      <div class="topbar-right">
        <i class="ti ti-calendar"></i>
        <span id="nowText"></span>
        <button class="refresh-btn" type="button" onclick="loadDashboardData()"><i class="ti ti-refresh"></i>새로고침</button>

        <div class="alert-area">
          <button class="alert-button" id="alertButton" type="button" title="알림">
            <i class="ti ti-bell"></i>
            <span class="alert-dot" id="alertDot"></span>
          </button>

          <div class="alert-dropdown" id="alertDropdown">
            <div class="alert-head">
              <strong>알림</strong>
              <button type="button" id="readAllBtn">모두 읽음</button>
            </div>

            <div class="alert-list">
              <div class="alert-item danger">
                <div class="alert-icon"><i class="ti ti-flame"></i></div>
                <div class="alert-text">
                  <strong>위험 감지</strong>
                  <span>#04 주차장 입구</span>
                  <small>연기감지값 350 / 온도 68.7°C</small>
                </div>
                <span class="alert-time">14:30:10</span>
              </div>

              <div class="alert-item warning">
                <div class="alert-icon"><i class="ti ti-alert-triangle"></i></div>
                <div class="alert-text">
                  <strong>주의 감지</strong>
                  <span>#03 놀이터 옆</span>
                  <small>연기감지값 120 / 온도 45.2°C</small>
                </div>
                <span class="alert-time">14:30:15</span>
              </div>

              <div class="alert-item success">
                <div class="alert-icon"><i class="ti ti-check"></i></div>
                <div class="alert-text">
                  <strong>정상 복귀</strong>
                  <span>#06 차고지 옆</span>
                  <small>센서 상태 정상</small>
                </div>
                <span class="alert-time">14:29:58</span>
              </div>
            </div>

            <button class="alert-more" type="button" id="openAllAlertsBtn">전체 알림 보기 →</button>
          </div>
        </div>
      </div>
    </div>

    <div class="content" id="dashboardContent">
      <div class="stat-row">
        <div class="stat-card total" onclick="filterTable('all', document.querySelector('.ft-btn'))">
          <div><div class="stat-label">전체 쓰레기통</div><div><span class="stat-num">8</span><span class="stat-unit">개</span></div><div class="stat-sub">등록된 전체 개수</div></div>
          <div class="stat-icon"><i class="ti ti-trash"></i></div>
        </div>
        <div class="stat-card danger" onclick="filterTable('danger', document.querySelector('.ft-btn:nth-child(2)'))">
          <div><div class="stat-label">위험</div><div><span class="stat-num">1</span><span class="stat-unit">개</span></div><div class="stat-pct">12.5%</div></div>
          <div class="stat-icon"><i class="ti ti-flame"></i></div>
        </div>
        <div class="stat-card warn" onclick="filterTable('warn', document.querySelector('.ft-btn:nth-child(3)'))">
          <div><div class="stat-label">주의</div><div><span class="stat-num">2</span><span class="stat-unit">개</span></div><div class="stat-pct">25.0%</div></div>
          <div class="stat-icon"><i class="ti ti-alert-triangle"></i></div>
        </div>
        <div class="stat-card good" onclick="filterTable('good', document.querySelector('.ft-btn:nth-child(4)'))">
          <div><div class="stat-label">정상</div><div><span class="stat-num">5</span><span class="stat-unit">개</span></div><div class="stat-pct">62.5%</div></div>
          <div class="stat-icon"><i class="ti ti-check"></i></div>
        </div>
      </div>

      <div class="mid-row">
        <div class="panel">
          <div class="panel-header">
            <div class="panel-title">쓰레기통 상태 현황</div>
            <div class="filter-toggle">
              <button class="ft-btn active-all" onclick="filterTable('all', this)">전체</button>
              <button class="ft-btn" onclick="filterTable('danger', this)">위험</button>
              <button class="ft-btn" onclick="filterTable('warn', this)">주의</button>
              <button class="ft-btn" onclick="filterTable('good', this)">정상</button>
            </div>
          </div>

          <table>
            <thead><tr><th>ID</th><th>설치 위치</th><th>상태</th><th>연기 감지값</th><th>온도</th><th>불꽃 감지</th><th>마지막 업데이트</th></tr></thead>
            <tbody id="status-tbody">
              <tr id="bin-1" class="danger-row" data-status="danger"><td>#04</td><td><div>#04 주차장 입구</div><div style="font-size:11px;color:#f87171;margin-top:2px;">서울시 마포구</div></td><td><span class="badge danger">위험</span></td><td><b>350</b></td><td><b>68.7°C</b></td><td>14:30:10</td></tr>
              <tr id="bin-2" class="warn-row" data-status="warn"><td>#03</td><td><div>놀이터 옆</div><div style="font-size:11px;color:#bbb;margin-top:2px;">서울시 마포구</div></td><td><span class="badge warn">주의</span></td><td>120</td><td>45.2°C</td><td>14:30:15</td></tr>
              <tr id="bin-3" class="warn-row" data-status="warn"><td>#07</td><td><div>운동장 입구</div><div style="font-size:11px;color:#bbb;margin-top:2px;">인천시 연수구</div></td><td><span class="badge warn">주의</span></td><td>110</td><td>43.5°C</td><td>14:30:03</td></tr>
              <tr id="bin-4" data-status="good"><td>#01</td><td><div>공원 입구</div><div style="font-size:11px;color:#bbb;margin-top:2px;">서울시 강남구</div></td><td><span class="badge ok">정상</span></td><td>12</td><td>28.4°C</td><td>14:30:20</td></tr>
              <tr id="bin-5" data-status="good"><td>#02</td><td><div>버스정류장</div><div style="font-size:11px;color:#bbb;margin-top:2px;">서울시 강남구</div></td><td><span class="badge ok">정상</span></td><td>18</td><td>29.1°C</td><td>14:30:18</td></tr>
              <tr id="bin-6" data-status="good"><td>#05</td><td><div>광장 중앙</div><div style="font-size:11px;color:#bbb;margin-top:2px;">부산시 해운대구</div></td><td><span class="badge ok">정상</span></td><td>9</td><td>27.8°C</td><td>14:30:08</td></tr>
              <tr id="bin-7" data-status="good"><td>#06</td><td><div>차고지 옆</div><div style="font-size:11px;color:#bbb;margin-top:2px;">부산시 해운대구</div></td><td><span class="badge ok">정상</span></td><td>15</td><td>30.2°C</td><td>14:30:05</td></tr>
              <tr id="bin-8" data-status="good"><td>#08</td><td><div>도서관 옆</div><div style="font-size:11px;color:#bbb;margin-top:2px;">인천시 연수구</div></td><td><span class="badge ok">정상</span></td><td>8</td><td>26.9°C</td><td>14:30:01</td></tr>
            </tbody>
          </table>
          <div class="more-row"><i class="ti ti-chevron-down" style="font-size:13px;vertical-align:-2px;"></i> 더보기</div>
        </div>

        <div class="panel">
          <div class="panel-header"><div class="panel-title">최근 알림</div><div class="panel-more" id="sideOpenAllAlerts">더보기 →</div></div>
          <div class="side-alert-list">
            <div class="side-alert-item"><div class="adot d"><i class="ti ti-flame"></i></div><div style="flex:1;min-width:0"><div class="at d">위험 감지</div><div class="aloc">#04 주차장 입구</div><div class="adesc">연기 감지값 350 / 온도 68.7°C</div></div><div class="atime">2026.05.29<br>14:30:10</div></div>
            <div class="side-alert-item"><div class="adot w"><i class="ti ti-alert-triangle"></i></div><div style="flex:1;min-width:0"><div class="at w">주의 감지</div><div class="aloc">#03 놀이터 옆</div><div class="adesc">연기 감지값 120 / 온도 45.2°C</div></div><div class="atime">2026.05.29<br>14:30:15</div></div>
            <div class="side-alert-item"><div class="adot w"><i class="ti ti-alert-triangle"></i></div><div style="flex:1;min-width:0"><div class="at w">주의 감지</div><div class="aloc">#07 운동장 입구</div><div class="adesc">연기 감지값 110 / 온도 43.5°C</div></div><div class="atime">2026.05.29<br>14:30:03</div></div>
            <div class="side-alert-item"><div class="adot o"><i class="ti ti-check"></i></div><div style="flex:1;min-width:0"><div class="at o">정상 복귀</div><div class="aloc">#06 차고지 옆</div><div class="adesc">상태가 정상으로 복귀했습니다.</div></div><div class="atime">2026.05.29<br>14:29:58</div></div>
          </div>
        </div>
      </div>

      <div class="bottom-bar">
        <div class="bot-item"><i class="bot-icon ti ti-wifi"></i><div><div class="bot-label">네트워크 상태</div><div class="bot-val ok">정상 연결</div></div></div>
        <div class="sep"></div>
        <div class="bot-item"><i class="bot-icon ti ti-clock"></i><div><div class="bot-label">마지막 동기화</div><div class="bot-val blue">방금 전</div></div></div>
        <div class="sep"></div>
        <div class="bot-item"><i class="bot-icon ti ti-server"></i><div><div class="bot-label">서버 상태</div><div class="bot-val ok">정상</div></div></div>
      </div>
    </div>
  </div>

  <div class="all-alert-overlay" id="allAlertOverlay">
    <div class="all-alert-modal">
      <div class="all-alert-header">
        <div><h2>전체 알림</h2><p>최근 감지된 알림 내역입니다.</p></div>
        <button type="button" id="closeAllAlertsBtn">×</button>
      </div>
      <div class="all-alert-list">
        <div class="all-alert-row danger"><div><strong>위험 감지</strong><span>#04 주차장 입구</span></div><p>연기감지값 350 / 온도 68.7°C</p><time>14:30:10</time></div>
        <div class="all-alert-row warning"><div><strong>주의 감지</strong><span>#03 놀이터 옆</span></div><p>연기감지값 120 / 온도 45.2°C</p><time>14:30:15</time></div>
        <div class="all-alert-row warning"><div><strong>주의 감지</strong><span>#07 운동장 입구</span></div><p>연기감지값 110 / 온도 43.5°C</p><time>14:30:03</time></div>
        <div class="all-alert-row success"><div><strong>정상 복귀</strong><span>#06 차고지 옆</span></div><p>센서 상태 정상</p><time>14:29:58</time></div>
      </div>
    </div>
  </div>

  <script>
const FIDS_ALERT_READ_KEY="fids_alerts_read_all";(function(){try{const n=performance.getEntriesByType("navigation")[0];if(n&&n.type==="reload"){sessionStorage.removeItem(FIDS_ALERT_READ_KEY);}}catch(e){}})();function fidsApplyAlertReadState(rows){const list=Array.isArray(rows)?rows:[];if(sessionStorage.getItem(FIDS_ALERT_READ_KEY)==="Y"){return list.map(row=>({...row,is_received:"Y"}));}return list;}function fidsMarkAlertsRead(){sessionStorage.setItem(FIDS_ALERT_READ_KEY,"Y");}

    const role = sessionStorage.getItem("role");
    const mgrName = sessionStorage.getItem("mgr_name");
    const mgrEmail = sessionStorage.getItem("mgr_email");

    if (!role) {
      alert("로그인이 필요합니다.");
      location.href = "/login";
    }

    document.getElementById("userName").textContent = mgrName || "관리자";
    document.getElementById("userEmail").textContent = mgrEmail || "";

    function setNowText() {
      const now = new Date();
      document.getElementById("nowText").textContent =
        now.getFullYear() + "." +
        String(now.getMonth() + 1).padStart(2, "0") + "." +
        String(now.getDate()).padStart(2, "0") + " " +
        String(now.getHours()).padStart(2, "0") + ":" +
        String(now.getMinutes()).padStart(2, "0") + ":" +
        String(now.getSeconds()).padStart(2, "0");
    }

    setNowText();
    setInterval(setNowText, 1000);

    document.getElementById("logoutBtn").addEventListener("click", () => {
      sessionStorage.clear();
      alert("\uB85C\uADF8\uC544\uC6C3\uB418\uC5C8\uC2B5\uB2C8\uB2E4.");
      location.replace("/");
    });

    function filterTable(type, btn) {
      document.querySelectorAll(".ft-btn").forEach((button) => { button.className = "ft-btn"; });
      if (type === "all") btn.className = "ft-btn active-all";
      else if (type === "danger") btn.className = "ft-btn active-danger";
      else if (type === "warn") btn.className = "ft-btn active-warn";
      else if (type === "good") btn.className = "ft-btn active-good";
      document.querySelectorAll("#status-tbody tr").forEach((tr) => {
        tr.classList.toggle("hidden", type !== "all" && tr.dataset.status !== type);
      });
    }

    function openAllAlerts() {
      document.getElementById("alertDropdown").classList.remove("open");
      document.getElementById("allAlertOverlay").classList.add("open");
    }

    const alertButton = document.getElementById("alertButton");
    const alertDropdown = document.getElementById("alertDropdown");
    const readAllBtn = document.getElementById("readAllBtn");
    const alertDot = document.getElementById("alertDot");
    const openAllAlertsBtn = document.getElementById("openAllAlertsBtn");
    const sideOpenAllAlerts = document.getElementById("sideOpenAllAlerts");
    const allAlertOverlay = document.getElementById("allAlertOverlay");
    const closeAllAlertsBtn = document.getElementById("closeAllAlertsBtn");

    alertButton.addEventListener("click", (event) => {
      event.stopPropagation();
      alertDropdown.classList.toggle("open");
    });

    readAllBtn.addEventListener("click", async () => {
      fidsMarkAlertsRead();
      await fetch("/alerts/read-all", { method: "POST" });
      await loadDashboardData();
    });

    openAllAlertsBtn.addEventListener("click", openAllAlerts);
    sideOpenAllAlerts.addEventListener("click", openAllAlerts);

    closeAllAlertsBtn.addEventListener("click", () => {
      allAlertOverlay.classList.remove("open");
    });

    allAlertOverlay.addEventListener("click", (event) => {
      if (event.target === allAlertOverlay) {
        allAlertOverlay.classList.remove("open");
      }
    });

    document.addEventListener("click", (event) => {
      if (!event.target.closest(".alert-area")) {
        alertDropdown.classList.remove("open");
      }
    });

    const params = new URLSearchParams(location.search);
    const binId = params.get("bin_id");
    if (binId) {
      const target = document.getElementById("bin-" + binId);
      if (target) {
        target.classList.add("focus-bin");
        target.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    }
  </script>
  <script>
    function dashboardStatusOf(row) {
      if (row.alert_type === "danger") return "danger";
      if (row.alert_type === "warning") return "warn";
      return "good";
    }

    function dashboardFallbackSensorValues(row) {
      const id = Number(row.bin_id);
      const dangerMap = { 1: [68.7, 350], 2: [68.7, 350], 3: [66.4, 328], 4: [64.9, 305] };
      const warningMap = { 5: [45.2, 120], 6: [43.5, 110], 7: [44.8, 108] };
      const normalMap = { 8: [28.4, 12], 9: [29.1, 18], 10: [27.8, 9], 11: [30.2, 15], 12: [26.9, 8] };
      const values = dangerMap[id] || warningMap[id] || normalMap[id] || (row.alert_type === "danger" ? [68.7, 350] : row.alert_type === "warning" ? [45.2, 120] : [28.4, 12]);
      return { temp: values[0], smoke: values[1], flame: row.alert_type === "danger" ? 1 : 0 };
    }

    function dashboardParseSmoke(row) {
      const match = String(row.alert_msg || "").match(/\uC5F0\uAE30\s*\uAC10\uC9C0\uAC12\s*(\d+)/);
      return match ? Number(match[1]) : dashboardFallbackSensorValues(row).smoke;
    }

    function dashboardParseTemp(row) {
      const match = String(row.alert_msg || "").match(/\uC628\uB3C4\s*([0-9.]+)/);
      return match ? Number(match[1]) : dashboardFallbackSensorValues(row).temp;
    }

    function dashboardParseFlame(row) {
      if (row.alert_type === "danger") return 1;
      const match = String(row.alert_msg || "").match(/\uBD88\uAF43\s*\uAC10\uC9C0\s*(0|1)/);
      return match ? Number(match[1]) : dashboardFallbackSensorValues(row).flame;
    }

    function dashboardTime(value) {
      if (!value) return "-";
      return new Date(value).toLocaleTimeString("ko-KR", {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit"
      });
    }

    function dashboardAlertTitle(type) {
      if (type === "danger") return "위험 감지";
      if (type === "warning") return "주의 감지";
      return "정상 복귀";
    }

    function dashboardAlertIcon(type) {
      if (type === "danger") return "ti-flame";
      if (type === "warning") return "ti-alert-triangle";
      return "ti-check";
    }

    let dashboardLastRefreshAt = new Date();
    async function loadDashboardData() {
      dashboardLastRefreshAt = new Date();
      const binResponse = await fetch("/trashbins/list");
      const alertResponse = await fetch("/alerts/list");
      const bins = await binResponse.json();
      let alerts = await alertResponse.json();
      alerts = fidsApplyAlertReadState(alerts);
      const sortRank = (type) => type === "danger" ? 1 : type === "warning" ? 2 : type === "normal" ? 3 : 4;
      bins.sort((a, b) => sortRank(a.alert_type) - sortRank(b.alert_type) || Number(a.bin_id) - Number(b.bin_id));
      alerts.sort((a, b) => sortRank(a.alert_type) - sortRank(b.alert_type) || Number(a.bin_id) - Number(b.bin_id));
      alertDot.classList.toggle("hide", !alerts.some((alert) => alert.alert_type === "danger" && alert.is_received !== "Y"));
      const danger = bins.filter((row) => row.alert_type === "danger").length;
      const warn = bins.filter((row) => row.alert_type === "warning").length;
      const good = bins.length - danger - warn;
      const statNums = document.querySelectorAll(".stat-num");

      statNums[0].textContent = bins.length;
      statNums[1].textContent = danger;
      statNums[2].textContent = warn;
      statNums[3].textContent = good;
      document.querySelector(".danger .stat-pct").textContent = bins.length ? ((danger / bins.length) * 100).toFixed(1) + "%" : "0%";
      document.querySelector(".warn .stat-pct").textContent = bins.length ? ((warn / bins.length) * 100).toFixed(1) + "%" : "0%";
      document.querySelector(".good .stat-pct").textContent = bins.length ? ((good / bins.length) * 100).toFixed(1) + "%" : "0%";

      const lastUpdateTime = dashboardTime(dashboardLastRefreshAt);
      document.getElementById("status-tbody").innerHTML = bins.map((row) => {
        const status = dashboardStatusOf(row);
        const label = status === "danger" ? "위험" : status === "warn" ? "주의" : "정상";
        const badge = status === "good" ? "ok" : status;
        return `<tr id="bin-${row.bin_id}" class="${status === "danger" ? "danger-row" : status === "warn" ? "warn-row" : ""}" data-status="${status}">
          <td>#${row.bin_id}</td>
          <td><div>${row.bin_loc || "-"}</div><div style="font-size:11px;color:#bbb;margin-top:2px;">Wi-Fi 연결</div></td>
          <td><span class="badge ${badge}">${label}</span></td>
          <td><b>${dashboardParseSmoke(row)}</b></td>
          <td><b>${dashboardParseTemp(row)}°C</b></td>
          <td><b>${dashboardParseFlame(row)}</b></td>
          <td>${lastUpdateTime}</td>
        </tr>`;
      }).join("");

      document.querySelector(".side-alert-list").innerHTML = alerts.filter((alert) => alert.alert_type === "danger").slice(0, 4).map((alert) => {
        const kind = alert.alert_type === "danger" ? "d" : alert.alert_type === "warning" ? "w" : "o";
        return `<div class="side-alert-item ${alert.is_received === "Y" ? "read" : ""}"><div class="adot ${kind}"><i class="ti ${dashboardAlertIcon(alert.alert_type)}"></i></div><div style="flex:1;min-width:0"><div class="at ${kind}">${dashboardAlertTitle(alert.alert_type)}</div><div class="aloc">#${alert.bin_id} ${alert.bin_loc || ""}</div><div class="adesc">${alert.alert_msg || "센서 상태 정상"}</div></div><div class="atime">${dashboardTime(alert.alerted_at)}</div></div>`;
      }).join("");

      document.querySelector(".alert-dropdown .alert-list").innerHTML = alerts.filter((alert) => alert.alert_type === "danger").slice(0, 5).map((alert) => {
        const type = alert.alert_type === "normal" ? "success" : alert.alert_type;
        return `<div class="alert-item ${type} ${alert.is_received === "Y" ? "read" : ""}"><div class="alert-icon"><i class="ti ${dashboardAlertIcon(alert.alert_type)}"></i></div><div class="alert-text"><strong>${dashboardAlertTitle(alert.alert_type)}</strong><span>#${alert.bin_id} ${alert.bin_loc || ""}</span><small>${alert.alert_msg || "센서 상태 정상"}</small></div><span class="alert-time">${dashboardTime(alert.alerted_at)}</span></div>`;
      }).join("");

      document.querySelector(".all-alert-list").innerHTML = alerts.filter((alert) => alert.alert_type === "danger").map((alert) => {
        const type = alert.alert_type === "normal" ? "success" : alert.alert_type;
        return `<div class="all-alert-row ${type} ${alert.is_received === "Y" ? "read" : ""}"><div><strong>${dashboardAlertTitle(alert.alert_type)}</strong><span>#${alert.bin_id} ${alert.bin_loc || ""}</span></div><p>${alert.alert_msg || "센서 상태 정상"}</p><time>${dashboardTime(alert.alerted_at)}</time></div>`;
      }).join("");

      const params = new URLSearchParams(location.search);
      const binId = params.get("bin_id");
      if (binId) {
        const target = document.getElementById("bin-" + binId);
        if (target) {
          target.classList.add("focus-bin");
          target.scrollIntoView({ behavior: "smooth", block: "center" });
        }
      }
    }

    loadDashboardData();
  </script>
  <script src="/js/fire-alert.js"></script>
<script>document.querySelectorAll(".operator-menu").forEach((item)=>{item.style.display=sessionStorage.getItem("role")==="operator"?"flex":"none";});</script>
<script>
  window.addEventListener("pageshow", function () {
    if (!sessionStorage.getItem("role")) {
      location.replace("/");
    }
  });
</script>
</body>
</html>
















