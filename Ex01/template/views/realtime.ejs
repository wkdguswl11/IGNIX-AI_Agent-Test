*{box-sizing:border-box;margin:0;padding:0}body{font-family:Pretendard,"Apple SD Gothic Neo",Arial,sans-serif;background:#f5f6fa;display:flex;height:100vh;overflow:hidden;color:#07112d}.sidebar{width:220px;background:#1a2235;display:flex;flex-direction:column;height:100vh;flex-shrink:0}.sb-logo{padding:20px 18px 16px;border-bottom:1px solid rgba(255,255,255,.08)}.sb-logo-title{font-size:16px;font-weight:700;color:#fff}.sb-logo-title span{display:inline-block;width:3px;height:16px;background:#2d6be4;border-radius:2px;margin-right:8px;vertical-align:middle}.sb-logo-sub{font-size:11px;color:rgba(255,255,255,.4);margin-top:2px}.sb-logo-sub2{font-size:10px;color:rgba(255,255,255,.3);margin-top:3px}.sb-nav{padding:14px 10px;flex:1}.nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;font-size:13px;color:rgba(255,255,255,.55);cursor:pointer;margin-bottom:2px}.nav-item.active,.nav-item:hover{background:rgba(255,255,255,.1);color:#fff}.nav-item i{font-size:17px}.sb-bottom{padding:14px 10px;border-top:1px solid rgba(255,255,255,.08)}.sb-user{display:flex;align-items:center;gap:10px;padding:10px 12px;margin-bottom:2px}.sb-avatar{width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center}.sb-avatar i{font-size:15px;color:rgba(255,255,255,.7)}.sb-user-name{font-size:12px;font-weight:600;color:#fff}.sb-user-email{font-size:10px;color:rgba(255,255,255,.4);margin-top:1px}.sb-logout{display:flex;align-items:center;gap:10px;padding:9px 12px;font-size:13px;color:rgba(255,255,255,.4);cursor:pointer;border-radius:8px}.sb-logout:hover{color:#fff;background:rgba(255,255,255,.06)}.main{flex:1;display:flex;flex-direction:column;overflow:hidden}.topbar{height:60px;background:#fff;border-bottom:1px solid #e5e7eb;padding:0 24px;display:flex;align-items:center;justify-content:space-between}.topbar-title{font-size:20px;font-weight:800}.topbar-right{display:flex;align-items:center;gap:14px;font-size:12px;color:#8a94a6}.live-dot{display:flex;align-items:center;gap:6px;font-weight:800;color:#16a34a}.live-dot:before{content:"";width:8px;height:8px;border-radius:50%;background:#16a34a}.refresh-btn{height:34px;border-radius:8px;display:flex;align-items:center;gap:6px;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;padding:0 12px;border:1px solid #e0e0e0;background:#fff;color:#555}.content{flex:1;overflow:hidden;display:flex;flex-direction:column;padding:20px;gap:16px}.stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}.stat-card{height:82px;background:#fff;border:1px solid #e1e6ef;border-radius:12px;padding:0 20px;display:flex;align-items:center;gap:18px}.stat-icon{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:21px}.stat-num{font-size:28px;font-weight:700;line-height:1}.stat-lbl{font-size:12px;color:#8b98b2;margin-top:5px}.info-banner{height:42px;background:#eff6ff;border:1px solid #93c5fd;border-radius:9px;padding:0 16px;display:flex;align-items:center;gap:10px}.info-banner i{color:#2d6be4}.info-banner p{font-size:12px;color:#1d4ed8}.body-wrap{flex:1;display:grid;grid-template-columns:minmax(0,1fr) 280px;gap:16px;min-height:0}.sensor-panel{display:flex;flex-direction:column;min-width:0;min-height:0}.sensor-head{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:10px}.sensor-title{font-size:16px;font-weight:700}.sensor-sub{font-size:12px;color:#8b98b2;margin-top:4px}.filters{display:flex;align-items:center;gap:8px}.search-box{width:280px;height:36px;display:flex;align-items:center;gap:8px;padding:0 12px;border:1px solid #dbe3ef;border-radius:8px;background:#fff;color:#8b98b2}.search-box input{border:0;outline:0;background:transparent;width:100%;font-size:12px}.filter-sel{height:36px;border:1px solid #dbe3ef;border-radius:8px;background:#fff;padding:0 10px;font-size:12px;font-family:inherit}.tabs{display:flex;gap:8px;margin:0 0 14px}.tab{height:30px;min-width:48px;border:0;border-radius:7px;background:transparent;color:#8b98b2;font-size:12px;font-weight:700;cursor:pointer}.tab.active{background:#fff;color:#07112d;box-shadow:0 1px 5px rgba(15,23,42,.1)}.sensor-list{flex:1;overflow-y:auto;padding-right:6px;display:flex;flex-direction:column;gap:10px}.sensor-card{background:#fff;border:1px solid #e1e6ef;border-radius:12px;overflow:hidden;flex-shrink:0}.sensor-card.danger{border-color:#ff7a7a;background:#fff7f7}.sensor-card.warning{border-color:#f2bc1b;background:#fffdf1}.card-top{height:48px;display:grid;grid-template-columns:52px 1fr 92px 28px;align-items:center;padding:0 18px}.sensor-id{font-size:13px;font-weight:900;color:#94a3b8}.sensor-id.danger{color:#dc2626}.name{font-size:15px;font-weight:700;color:#07112d}.addr{font-size:12px;color:#8b98b2;margin-top:3px}.badge{justify-self:end;display:inline-flex;align-items:center;gap:5px;height:26px;padding:0 12px;border-radius:999px;font-size:12px;font-weight:700}.badge.danger{background:#fee2e2;color:#dc2626}.badge.warning{background:#fef3c7;color:#b45309}.badge.normal{background:#dcfce7;color:#15803d}.chev{color:#9aa6bb;font-size:16px;justify-self:end}.card-body{display:none;border-top:1px solid #edf1f7}.sensor-card.open .card-body{display:grid;grid-template-columns:repeat(5,1fr);min-height:92px}.metric{display:flex;flex-direction:column;align-items:center;justify-content:center;border-right:1px solid #edf1f7}.metric:last-child{border-right:0}.metric-label{font-size:12px;color:#9aa6bb;margin-bottom:8px}.metric-value{font-size:18px;font-weight:700}.metric-value.danger{color:#dc2626}.metric-value.warning{color:#d97706}.metric-value.normal{color:#07112d}.unit{font-size:11px;color:#8b98b2;font-weight:500}.card-foot{grid-column:1/-1;text-align:right;padding:0 18px 12px;color:#c3cad8;font-size:11px}.side{display:flex;flex-direction:column;gap:14px;min-height:0;overflow-y:auto}.side-card{background:#fff;border:1px solid #e1e6ef;border-radius:12px;padding:16px}.side-title{font-size:14px;font-weight:900;margin-bottom:14px}.calendar-head{display:flex;align-items:center;justify-content:space-between;color:#94a3b8}.calendar-title{font-size:13px;font-weight:900;color:#172033}.week{display:grid;grid-template-columns:repeat(7,1fr);text-align:center;font-size:11px;color:#8b98b2;margin-top:18px}.calendar-days{display:grid;grid-template-columns:repeat(7,1fr);gap:6px;margin-top:10px}.calendar-day{height:28px;border:0;border-radius:7px;background:#fff;color:#64748b;font-size:12px;cursor:pointer}.calendar-day:hover,.calendar-day.active{background:#2563eb;color:#fff;font-weight:800}.record-empty{height:70px;display:flex;align-items:center;justify-content:center;color:#a7b0c2;font-size:12px}.event{display:flex;gap:8px;padding:9px 0;border-bottom:1px solid #f1f4f8}.dot{width:8px;height:8px;border-radius:50%;margin-top:5px}.dot.danger{background:#dc2626}.dot.warning{background:#d97706}.dot.normal{background:#16a34a}.event-title{font-size:12px;font-weight:800}.event-title.danger{color:#dc2626}.event-title.warning{color:#d97706}.event-title.normal{color:#16a34a}.event-desc,.event-time{font-size:11px;color:#94a3b8}.alert-area{position:relative}.alert-button{position:relative;width:38px;height:38px;border:1px solid #e5e7eb;border-radius:50%;background:#fff;cursor:pointer;font-size:17px;display:grid;place-items:center}.alert-dot{position:absolute;top:7px;right:8px;width:8px;height:8px;background:#ef4444;border-radius:50%;border:2px solid #fff}.alert-dot.hide{display:none}.alert-dropdown{display:none;position:absolute;top:46px;right:0;width:330px;background:#fff;border:1px solid #e5e7eb;border-radius:12px;box-shadow:0 18px 45px rgba(15,23,42,.18);overflow:hidden;z-index:50}.alert-dropdown.open{display:block}.alert-head{display:flex;justify-content:space-between;padding:16px 18px;border-bottom:1px solid #eef2f7}.alert-head button,.alert-more{border:0;background:#fff;color:#2563eb;cursor:pointer}.alert-list{max-height:300px;overflow-y:auto}.alert-item{display:grid;grid-template-columns:42px 1fr 56px;gap:10px;padding:14px 16px;border-bottom:1px solid #f1f5f9}.alert-item.danger{background:#fff5f5}.alert-icon{width:34px;height:34px;border-radius:50%;display:grid;place-items:center}.alert-item.danger .alert-icon{background:#fee2e2;color:#ef4444}.alert-item.warning .alert-icon{background:#fef3c7;color:#f59e0b}.alert-item.normal .alert-icon{background:#d1fae5;color:#10b981}.alert-text{display:flex;flex-direction:column;gap:4px}.alert-text strong{font-size:14px}.alert-text span{font-size:13px}.alert-text small,.alert-time{font-size:12px;color:#9ca3af}.alert-more{width:100%;height:42px;font-weight:700}.all-alert-overlay{display:none;position:fixed;inset:0;background:rgba(15,23,42,.45);z-index:9000;align-items:center;justify-content:center}.all-alert-overlay.open{display:flex}.all-alert-modal{width:720px;max-height:80vh;background:#fff;border-radius:16px;box-shadow:0 24px 70px rgba(15,23,42,.25);overflow:hidden}.all-alert-header{display:flex;justify-content:space-between;padding:22px 24px;border-bottom:1px solid #e5e7eb}.all-alert-header button{width:36px;height:36px;border:0;border-radius:50%;font-size:24px}.all-alert-list{max-height:58vh;overflow:auto;padding:10px}.all-alert-row{display:grid;grid-template-columns:180px 1fr 90px;gap:16px;padding:16px;border-bottom:1px solid #f1f5f9}.all-alert-row.danger{background:#fff5f5}.all-alert-row.warning{background:#fffbeb}.all-alert-row.normal{background:#ecfdf5}
