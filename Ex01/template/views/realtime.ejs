.operator-menu{display:none}.alert-item:not(.read) .alert-text strong{color:#111827!important;font-weight:800!important}.alert-item:not(.read) .alert-text span{color:#1f2937!important}.alert-item:not(.read) .alert-text small,.alert-item:not(.read) .alert-time{color:#6b7280!important}.all-alert-row:not(.read) strong{color:#111827!important;font-weight:800!important}.all-alert-row:not(.read) span,.all-alert-row:not(.read) p,.all-alert-row:not(.read) time{color:#1f2937!important}</style></head><body>
<div class="sidebar"><div class="sb-logo"><div class="sb-logo-title"><span></span>FIDS</div><div class="sb-logo-sub2">쓰레기통 화재 감지 시스템</div><div class="sb-logo-sub">관리자 대시보드</div></div><div class="sb-nav"><div class="nav-item" onclick="location.href='/dashboard'"><i class="ti ti-home"></i>대시보드</div><div class="nav-item" onclick="location.href='/trashbins'"><i class="ti ti-trash"></i>쓰레기통 관리</div><div class="nav-item active" onclick="location.href='/realtime'"><i class="ti ti-chart-line"></i>실시간 모니터링</div><div class="nav-item" onclick="location.href='/alert'"><i class="ti ti-bell"></i>알림 기록</div><div class="nav-item operator-menu" onclick="location.href='/admin/approval'"><i class="ti ti-user-check"></i>관리자 승인 관리</div><div class="nav-item" onclick="location.href='/settings'"><i class="ti ti-settings"></i>설정</div><div class="nav-item" onclick="location.href='/'"><i class="ti ti-home-2"></i>메인페이지</div></div><div class="sb-bottom"><div class="sb-user"><div class="sb-avatar"><i class="ti ti-user"></i></div><div><div id="userName" class="sb-user-name">관리자</div><div id="userEmail" class="sb-user-email">admin@korea.kr</div></div></div><div id="logoutBtn" class="sb-logout"><i class="ti ti-logout"></i>로그아웃</div></div></div>
<div class="main"><div class="topbar"><div class="topbar-title">실시간 모니터링</div><div class="topbar-right"><span class="live-dot">LIVE</span><span>·</span><i class="ti ti-calendar"></i><span id="nowText"></span><button class="refresh-btn" type="button" onclick="loadRealtimeData()"><i class="ti ti-refresh"></i>새로고침</button><div class="alert-area"><button class="alert-button" id="alertButton"><i class="ti ti-bell"></i><span class="alert-dot" id="alertDot"></span></button><div class="alert-dropdown" id="alertDropdown"><div class="alert-head"><strong>알림</strong><button id="readAllBtn">모두 읽음</button></div><div class="alert-list" id="alertList"></div><button class="alert-more" id="openAllAlertsBtn">전체 알림 보기 →</button></div></div></div></div>
<div class="content"><div class="stat-row"><div class="stat-card" onclick="setStatusFilter('')"><div class="stat-icon" style="background:#eff6ff;color:#3b82f6"><i class="ti ti-map-pin"></i></div><div><div class="stat-num" id="totalCount">0</div><div class="stat-lbl">등록된 설치 위치</div></div></div><div class="stat-card" onclick="setStatusFilter('danger')"><div class="stat-icon" style="background:#fee2e2;color:#dc2626"><i class="ti ti-flame"></i></div><div><div class="stat-num" id="dangerCount" style="color:#dc2626">0</div><div class="stat-lbl">위험 경보</div></div></div><div class="stat-card" onclick="setStatusFilter('warning')"><div class="stat-icon" style="background:#fef3c7;color:#d97706"><i class="ti ti-alert-triangle"></i></div><div><div class="stat-num" id="warningCount" style="color:#d97706">0</div><div class="stat-lbl">주의 감지</div></div></div><div class="stat-card" onclick="setStatusFilter('normal')"><div class="stat-icon" style="background:#dcfce7;color:#16a34a"><i class="ti ti-check"></i></div><div><div class="stat-num" id="normalCount" style="color:#16a34a">0</div><div class="stat-lbl">정상 운영 중</div></div></div></div><div class="info-banner"><i class="ti ti-info-circle"></i><p>설치 위치는 관리자가 <b>쓰레기통 관리</b> 메뉴에서 등록한 주소 기반으로 표시됩니다. 실제 GPS 위치가 아닌 등록된 설치 주소를 기준으로 센서 데이터를 매핑합니다.</p></div><div class="body-wrap"><section class="sensor-panel"><div class="sensor-head"><div><div class="sensor-title">설치 위치별 센서 현황</div><div class="sensor-sub" id="listSub">센서 데이터 로딩 중</div></div><div class="filters"><select class="filter-sel" id="statusFilter" onchange="renderSensors()"><option value="">전체</option><option value="danger">위험</option><option value="warning">주의</option><option value="normal">정상</option></select></div></div><div class="tabs"><button class="tab active" data-type="" onclick="setStatusFilter('')">전체</button><button class="tab" data-type="danger" onclick="setStatusFilter('danger')">위험</button><button class="tab" data-type="warning" onclick="setStatusFilter('warning')">주의</button><button class="tab" data-type="normal" onclick="setStatusFilter('normal')">정상</button></div><div class="sensor-list" id="sensorList"></div></section><aside class="side"><div class="side-card"><div class="side-title">실시간 이벤트</div><div id="eventList"></div></div><div class="side-card"><div class="side-title">날짜별 기록</div><div class="calendar-head"><i class="ti ti-chevron-left" onclick="moveRecordMonth(-1)"></i><span class="calendar-title" id="calendarTitle"></span><i class="ti ti-chevron-right" onclick="moveRecordMonth(1)"></i></div><div class="week"><span style="color:#dc2626">일</span><span>월</span><span>화</span><span>수</span><span>목</span><span>금</span><span style="color:#4267b2">토</span></div><div class="calendar-days" id="calendarDays"></div></div><div class="side-card"><div class="side-title" id="recordTitle">기록 없음</div><div class="record-empty" id="recordList">날짜를 선택하세요</div></div></aside></div></div></div>
<div class="all-alert-overlay" id="allAlertOverlay"><div class="all-alert-modal"><div class="all-alert-header"><div><h2>전체 알림</h2><p>최근 감지된 알림 내역입니다.</p></div><button id="closeAllAlertsBtn">×</button></div><div class="all-alert-list" id="allAlertList"></div></div></div>
<script>
const FIDS_ALERT_READ_KEY="fids_alerts_read_all";(function(){try{const n=performance.getEntriesByType("navigation")[0];if(n&&n.type==="reload"){sessionStorage.removeItem(FIDS_ALERT_READ_KEY);}}catch(e){}})();function fidsApplyAlertReadState(rows){const list=Array.isArray(rows)?rows:[];if(sessionStorage.getItem(FIDS_ALERT_READ_KEY)==="Y"){return list.map(row=>({...row,is_received:"Y"}));}return list;}function fidsMarkAlertsRead(){sessionStorage.setItem(FIDS_ALERT_READ_KEY,"Y");}function fidsAlertsAreRead(){return sessionStorage.getItem(FIDS_ALERT_READ_KEY)==="Y";}function fidsClearReadOnReload(){try{const n=performance.getEntriesByType("navigation")[0];if(n&&n.type==="reload"){sessionStorage.removeItem(FIDS_ALERT_READ_KEY);}}catch(e){}}

let sensors=[],alerts=[],opened=new Set();let selectedRecordDateKey="";let calendarViewDate=new Date();const role=sessionStorage.getItem("role"),mgrName=sessionStorage.getItem("mgr_name"),mgrEmail=sessionStorage.getItem("mgr_email");if(!role){alert("로그인이 필요합니다.");location.href="/login"}userName.textContent=mgrName||"관리자";userEmail.textContent=mgrEmail||"";logoutBtn.onclick=()=>{sessionStorage.clear();alert("\uB85C\uADF8\uC544\uC6C3\uB418\uC5C8\uC2B5\uB2C8\uB2E4.");location.replace("/")};function tick(){const n=new Date();nowText.textContent=n.getFullYear()+"."+String(n.getMonth()+1).padStart(2,"0")+"."+String(n.getDate()).padStart(2,"0")+" (화) "+String(n.getHours()).padStart(2,"0")+":"+String(n.getMinutes()).padStart(2,"0")+":"+String(n.getSeconds()).padStart(2,"0")}function statusOf(r){if(r.alert_type==="danger")return"danger";if(r.alert_type==="warning")return"warning";return"normal"}function statusText(s){return s==="danger"?"위험":s==="warning"?"주의":"정상"}function rank(s){return s==="danger"?1:s==="warning"?2:3}function ftime(v){return v?new Date(v).toLocaleTimeString("ko-KR",{hour:"2-digit",minute:"2-digit",second:"2-digit"}):"-"}function splitRegion(loc){const p=String(loc||"").trim().split(/\s+/);const city=p[0]||"";const gun=p[1]||"";const ok=/([\uC2DC\uB3C4]|\uD2B9\uBCC4\uC2DC|\uAD11\uC5ED\uC2DC|\uD2B9\uBCC4\uC790\uCE58\uC2DC|\uD2B9\uBCC4\uC790\uCE58\uB3C4)$/.test(city);return{city:ok?city:"\uAE30\uD0C0",gun:ok&&gun?gun:"\uBBF8\uBD84\uB958"}}function enrich(r){const rg=splitRegion(r.bin_loc);return{...r,city:rg.city,gun:rg.gun}}function sensorFallback(r){const id=Number(r.bin_id);const dangerMap={1:[68.7,350],2:[68.7,350],3:[66.4,328],4:[64.9,305]};const warningMap={5:[45.2,120],6:[43.5,110],7:[44.8,108]};const normalMap={8:[28.4,12],9:[29.1,18],10:[27.8,9],11:[30.2,15],12:[26.9,8]};const values=dangerMap[id]||warningMap[id]||normalMap[id]||(statusOf(r)==="danger"?[68.7,350]:statusOf(r)==="warning"?[45.2,120]:[28.4,12]);return{temp:values[0],smoke:values[1],flame:statusOf(r)==="danger"?1:0}}function temp(r){const m=String(r.alert_msg||"").match(/\uC628\uB3C4\s*([0-9.]+)/);return m?Number(m[1]).toFixed(1):sensorFallback(r).temp.toFixed(1)}function smoke(r){const m=String(r.alert_msg||"").match(/\uC5F0\uAE30\s*\uAC10\uC9C0\uAC12\s*(\d+)/);return m?Number(m[1]):sensorFallback(r).smoke}function flame(r){if(statusOf(r)==="danger")return 1;const m=String(r.alert_msg||"").match(/\uBD88\uAF43\s*\uAC10\uC9C0\s*(0|1)/);return m?Number(m[1]):sensorFallback(r).flame}function wifi(r){return Math.max(-79,Math.min(-49,-48-Math.round(smoke(r)/11)))}function battery(r){return statusOf(r)==="normal"?"정상":"저전압"}function updateGunFilter(){}function updateFilters(){}function setStatusFilter(t){statusFilter.value=t;document.querySelectorAll(".tab").forEach(b=>b.classList.toggle("active",b.dataset.type===t));renderSensors()}function initOpen(){if(opened.size)return;["danger","warning","normal"].forEach(st=>{const row=sensors.find(s=>statusOf(s)===st);if(row)opened.add(String(row.bin_id))})}function toggleOpen(id){id=String(id);opened.has(id)?opened.delete(id):opened.add(id);renderSensors()}function renderStats(){const total=sensors.length,d=sensors.filter(s=>statusOf(s)==="danger").length,w=sensors.filter(s=>statusOf(s)==="warning").length,n=sensors.filter(s=>statusOf(s)==="normal").length;totalCount.textContent=total;dangerCount.textContent=d;warningCount.textContent=w;normalCount.textContent=n;listSub.textContent=`총 ${total}개 센서 · 위험 ${d}개 · 주의 ${w}개 · 정상 ${n}개`}function renderSensors(){const kw="",sf=statusFilter.value,city="",gun="";const rows=sensors.filter(r=>{const st=statusOf(r),text=(`${r.bin_id} ${r.bin_loc||""} ${r.city} ${r.gun}`).toLowerCase();return(!kw||text.includes(kw))&&(!sf||st===sf)&&(!city||r.city===city)&&(!gun||r.gun===gun)}).sort((a,b)=>rank(statusOf(a))-rank(statusOf(b))||Number(a.bin_id)-Number(b.bin_id));sensorList.innerHTML=rows.map(r=>{const st=statusOf(r),tm=temp(r),sm=smoke(r),fl=flame(r),wf=wifi(r),open=opened.has(String(r.bin_id));return `<article class="sensor-card ${st} ${open?"open":""}"><div class="card-top" onclick="toggleOpen(${r.bin_id})"><span class="sensor-id ${st}">#${String(r.bin_id).padStart(2,"0")}</span><div><div class="name">${r.bin_loc||"-"}</div><div class="addr">${r.city} ${r.gun}</div></div><span class="badge ${st}"><i class="ti ${st==="danger"?"ti-flame":st==="warning"?"ti-alert-triangle":"ti-check"}"></i>${statusText(st)}</span><i class="chev ti ${open?"ti-chevron-up":"ti-chevron-down"}"></i></div><div class="card-body"><div class="metric"><div class="metric-label">온도</div><div class="metric-value ${st}">${tm}<span class="unit"> ℃</span></div></div><div class="metric"><div class="metric-label">연기감지값</div><div class="metric-value ${st}">${sm}</div></div><div class="metric"><div class="metric-label">불꽃 감지</div><div class="metric-value ${st}">${fl}</div></div><div class="metric"><div class="metric-label">Wi-Fi</div><div class="metric-value ${st}">${wf} dBm</div></div><div class="metric"><div class="metric-label">건전지</div><div class="metric-value ${st}">${battery(r)}</div></div><div class="card-foot">마지막 수신: ${ftime(r.alerted_at)}</div></div></article>`}).join("")||'<div class="side-card" style="text-align:center;color:#94a3b8">조건에 맞는 센서가 없습니다.</div>';renderStats()}function atitle(t){return t==="danger"?"위험 감지":t==="warning"?"주의 감지":"정상 복귀"}function aicon(t){return t==="danger"?"ti-flame":t==="warning"?"ti-alert-triangle":"ti-check"}function renderAlerts(){alertDot.classList.toggle("hide", fidsAlertsAreRead() || !alerts.some(a=>a.alert_type==="danger"));const dangerAlerts=alerts.filter(a=>a.alert_type==="danger");alertList.innerHTML=dangerAlerts.slice(0,5).map(a=>`<div class="alert-item ${a.alert_type} ${fidsAlertsAreRead()?"read":""}"><div class="alert-icon"><i class="ti ${aicon(a.alert_type)}"></i></div><div class="alert-text"><strong>${atitle(a.alert_type)}</strong><span>#${a.bin_id} ${a.bin_loc||""}</span><small>${a.alert_msg||"센서 상태 정상"}</small></div><span class="alert-time">${ftime(a.alerted_at)}</span></div>`).join("");allAlertList.innerHTML=dangerAlerts.map(a=>`<div class="all-alert-row ${a.alert_type} ${fidsAlertsAreRead()?"read":""}"><div><strong>${atitle(a.alert_type)}</strong><span>#${a.bin_id} ${a.bin_loc||""}</span></div><p>${a.alert_msg||"센서 상태 정상"}</p><time>${ftime(a.alerted_at)}</time></div>`).join("");eventList.innerHTML=alerts.filter(a=>a.alert_type==="danger").slice(0,5).map(a=>`<div class="event"><span class="dot ${a.alert_type}"></span><div><div class="event-title ${a.alert_type}">${atitle(a.alert_type)}</div><div class="event-desc">#${a.bin_id} ${a.bin_loc||""}</div></div><span class="event-time">${ftime(a.alerted_at)}</span></div>`).join("")}function recordPad(n){return String(n).padStart(2,"0")}function recordKey(d){return d.getFullYear()+"-"+recordPad(d.getMonth()+1)+"-"+recordPad(d.getDate())}function renderCalendarDays(){if(!selectedRecordDateKey)selectedRecordDateKey=recordKey(new Date());const now=calendarViewDate,year=now.getFullYear(),month=now.getMonth(),first=new Date(year,month,1),last=new Date(year,month+1,0).getDate();calendarTitle.textContent=year+"년 "+String(month+1)+"월";let html="";for(let i=0;i<first.getDay();i++)html+="<span></span>";for(let day=1;day<=last;day++){const key=recordKey(new Date(year,month,day));html+=`<button class="calendar-day ${key===selectedRecordDateKey?"active":""}" type="button" onclick="selectRecordDate('${key}')">${day}</button>`}calendarDays.innerHTML=html}function selectRecordDate(key){selectedRecordDateKey=key;renderCalendarDays();renderDateRecords()}function moveRecordMonth(diff){calendarViewDate=new Date(calendarViewDate.getFullYear(),calendarViewDate.getMonth()+diff,1);selectedRecordDateKey=recordKey(calendarViewDate);renderCalendarDays();renderDateRecords()}function renderDateRecords(){if(!selectedRecordDateKey)selectedRecordDateKey=recordKey(new Date());const rows=alerts.filter(a=>a.alerted_at&&recordKey(new Date(a.alerted_at))===selectedRecordDateKey);recordTitle.textContent=selectedRecordDateKey+" 기록";recordList.className=rows.length?"":"record-empty";recordList.innerHTML=rows.length?rows.map(a=>`<div class="event"><span class="dot ${a.alert_type}"></span><div><div class="event-title ${a.alert_type}">${atitle(a.alert_type)}</div><div class="event-desc">#${a.bin_id} ${a.bin_loc||""}</div><div class="event-time">${ftime(a.alerted_at)}</div></div></div>`).join(""):"선택한 날짜의 기록이 없습니다."}async function loadRealtimeData(){const br=await fetch("/trashbins/list"),ar=await fetch("/alerts/list");sensors=(await br.json()).map(enrich);alerts=fidsApplyAlertReadState(await ar.json());updateFilters();initOpen();renderSensors();renderAlerts();renderCalendarDays();renderDateRecords()}alertButton.onclick=e=>{e.stopPropagation();alertDropdown.classList.toggle("open")};readAllBtn.onclick=async()=>{fidsMarkAlertsRead();await fetch("/alerts/read-all",{method:"POST"});await loadRealtimeData();};openAllAlertsBtn.onclick=()=>{alertDropdown.classList.remove("open");allAlertOverlay.classList.add("open")};closeAllAlertsBtn.onclick=()=>allAlertOverlay.classList.remove("open");document.onclick=e=>{if(!e.target.closest(".alert-area"))alertDropdown.classList.remove("open")};tick();setInterval(tick,1000);loadRealtimeData();setInterval(loadRealtimeData,10000);
</script><script src="/js/fire-alert.js"></script><script>document.querySelectorAll(".operator-menu").forEach((item)=>{item.style.display=sessionStorage.getItem("role")==="operator"?"flex":"none";});</script>
