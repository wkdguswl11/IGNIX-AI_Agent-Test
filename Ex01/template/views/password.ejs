<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>비밀번호 설정 - FIDS</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: "Pretendard", "Apple SD Gothic Neo", Arial, sans-serif;
      background: #f5f6fa;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: #10172f;
    }

    .brand {
      text-align: center;
      margin-bottom: 28px;
    }

    .brand-title {
      font-size: 26px;
      font-weight: 700;
      letter-spacing: 1px;
      color: #16213a;
    }

    .brand-line {
      display: block;
      width: 32px;
      height: 3px;
      background: #2d6be4;
      border-radius: 2px;
      margin: 8px auto 12px;
    }

    .brand-desc {
      font-size: 13px;
      color: #9aa0ad;
      line-height: 1.7;
    }

    .page {
      width: 480px;
      background: #fff;
      border: 1px solid #e8e9ed;
      border-radius: 16px;
      padding: 40px 48px;
      box-shadow: 0 4px 40px rgba(0, 0, 0, 0.08);
    }

    .icon-wrap {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background: #eff6ff;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }

    .icon-wrap i {
      font-size: 32px;
      color: #2d6be4;
    }

    .form-title {
      font-size: 22px;
      font-weight: 800;
      color: #0f172f;
      margin-bottom: 6px;
      text-align: center;
    }

    .form-sub {
      font-size: 13px;
      color: #9aa0ad;
      margin-bottom: 26px;
      text-align: center;
    }

    .field {
      margin-bottom: 14px;
      width: 100%;
    }

    .field label {
      display: block;
      font-size: 12px;
      font-weight: 700;
      color: #444b5c;
      margin-bottom: 7px;
    }

    .input-wrap {
      position: relative;
    }

    .input-wrap i.left-icon {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 16px;
      color: #c3c7d0;
    }

    .input-wrap input {
      width: 100%;
      height: 44px;
      border-radius: 9px;
      border: 1.5px solid #e4e7ee;
      background: #fbfbfc;
      padding: 0 40px 0 38px;
      font-size: 14px;
      color: #222;
      outline: none;
      transition: border .15s, background .15s;
      font-family: inherit;
    }

    .input-wrap input:focus {
      border-color: #2d6be4;
      background: #fff;
    }

    .eye-btn {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 16px;
      color: #c3c7d0;
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
    }

    .eye-btn:hover {
      color: #888;
    }

    .pw-rules {
      margin-top: 10px;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .pw-rule {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: #bbb;
    }

    .pw-rule.ok {
      color: #22c55e;
    }

    .pw-rule i {
      font-size: 13px;
    }

    #match-hint {
      font-size: 11px;
      margin-top: 6px;
    }

    .btn-primary {
      width: 100%;
      height: 46px;
      border-radius: 10px;
      background: #1a2235;
      border: none;
      color: #fff;
      font-size: 14px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      cursor: pointer;
      margin-top: 8px;
      font-family: inherit;
    }

    .btn-primary:hover {
      background: #243040;
    }
  </style>
</head>
<body>
  <div class="brand">
    <div class="brand-title">FIDS</div>
    <span class="brand-line"></span>
    <div class="brand-desc">
      공공 쓰레기통 내 화재를 실시간으로<br>
      감지하고 관리하는 스마트 플랫폼
    </div>
  </div>

  <div class="page">
    <div class="icon-wrap"><i class="ti ti-lock"></i></div>

    <div class="form-title">비밀번호 설정</div>
    <div class="form-sub">사용할 비밀번호를 입력해주세요</div>

    <div class="field">
      <label>비밀번호</label>
      <div class="input-wrap">
        <i class="left-icon ti ti-lock"></i>
        <input id="pw" type="password" placeholder="8자 이상, 영문+숫자+특수문자">
        <button class="eye-btn" type="button" onclick="togglePw('pw', this)">
          <i class="ti ti-eye"></i>
        </button>
      </div>

      <div class="pw-rules">
        <div class="pw-rule" id="rule-len"><i class="ti ti-circle"></i>8자 이상</div>
        <div class="pw-rule" id="rule-eng"><i class="ti ti-circle"></i>영문 포함</div>
        <div class="pw-rule" id="rule-num"><i class="ti ti-circle"></i>숫자 포함</div>
        <div class="pw-rule" id="rule-spc"><i class="ti ti-circle"></i>특수문자 포함</div>
      </div>
    </div>

    <div class="field">
      <label>비밀번호 확인</label>
      <div class="input-wrap">
        <i class="left-icon ti ti-lock-check"></i>
        <input id="pw2" type="password" placeholder="비밀번호 재입력">
        <button class="eye-btn" type="button" onclick="togglePw('pw2', this)">
          <i class="ti ti-eye"></i>
        </button>
      </div>
      <div id="match-hint"></div>
    </div>

    <button id="joinBtn" class="btn-primary" type="button">
      <i class="ti ti-check"></i>
      가입완료
    </button>
  </div>

  <script>
    const mgrName = sessionStorage.getItem("mgr_name");
    const mgrEmail = sessionStorage.getItem("mgr_email");
    const mgrOrg = sessionStorage.getItem("organization");

    if (!mgrName || !mgrEmail) {
      alert("회원가입 정보가 없습니다. 회원가입 화면으로 이동합니다.");
      location.href = "/join";
    }

    function togglePw(id, btn) {
      const input = document.getElementById(id);
      const isText = input.type === "text";

      input.type = isText ? "password" : "text";
      btn.querySelector("i").className = isText ? "ti ti-eye" : "ti ti-eye-off";
    }

    function checkPw() {
      const pw = document.getElementById("pw").value;

      const rules = [
        { id: "rule-len", ok: pw.length >= 8 },
        { id: "rule-eng", ok: /[a-zA-Z]/.test(pw) },
        { id: "rule-num", ok: /[0-9]/.test(pw) },
        { id: "rule-spc", ok: /[^a-zA-Z0-9]/.test(pw) }
      ];

      rules.forEach((rule) => {
        const el = document.getElementById(rule.id);
        el.classList.toggle("ok", rule.ok);
        el.querySelector("i").className = rule.ok ? "ti ti-circle-check" : "ti ti-circle";
      });

      checkMatch();

      return rules.every((rule) => rule.ok);
    }

    function checkMatch() {
      const pw = document.getElementById("pw").value;
      const pw2 = document.getElementById("pw2").value;
      const hint = document.getElementById("match-hint");

      if (!pw2) {
        hint.textContent = "";
        return false;
      }

      if (pw === pw2) {
        hint.textContent = "비밀번호가 일치합니다.";
        hint.style.color = "#22c55e";
        return true;
      }

      hint.textContent = "비밀번호가 일치하지 않습니다.";
      hint.style.color = "#ef4444";
      return false;
    }

    document.getElementById("pw").addEventListener("input", checkPw);
    document.getElementById("pw2").addEventListener("input", checkMatch);

    document.getElementById("joinBtn").addEventListener("click", async () => {
      const pw = document.getElementById("pw").value;

      if (!checkPw()) {
        alert("비밀번호 조건을 확인해주세요.");
        return;
      }

      if (!checkMatch()) {
        alert("비밀번호 확인이 일치하지 않습니다.");
        return;
      }

      const response = await fetch("/manager/join", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          mgr_email: mgrEmail,
          mgr_pw: pw,
          mgr_name: mgrName,
          mgr_phone: "",
          mgr_org: mgrOrg || ""
        })
      });

      const result = await response.text();

      if (result === "회원가입 신청 완료") {
        location.href = "/pending";
      } else {
        alert(result);
      }
    });
  </script>
</body>
</html>



